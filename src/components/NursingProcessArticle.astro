{qrDataUrl && (
  <div
    id="qr-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="qr-modal-title"
    style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.55); z-index:1000; align-items:center; justify-content:center;"
  >
    <div style="background:#fff; border-radius:1rem; padding:2rem; max-width:320px; width:90%; text-align:center; position:relative; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
      <button
        id="qr-modal-close"
        aria-label="Close QR code modal"
        style="position:absolute; top:0.75rem; right:0.85rem; background:none; border:none; font-size:1.4rem; line-height:1; cursor:pointer; color:#64748b;"
      >×</button>
      <p id="qr-modal-title" style="font-weight:700; color:#1e293b; margin-bottom:1rem; font-size:1rem;">📱 Reveal Link QR Code</p>
      <img
        src={qrDataUrl}
        alt="QR code for the public reveal link"
