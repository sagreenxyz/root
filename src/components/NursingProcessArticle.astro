        height="240"
        style="display:block; margin:0 auto 1rem; border:1px solid #e2e8f0; border-radius:0.5rem;"
      />
      <p style="font-size:0.8rem; color:#64748b; margin:0;">Scan with your phone to open the reveal link</p>
    </div>
  </div>
)}

