<script>
  /**
   * Reveal-link copy button — only shown when the user is authenticated.
   * After a successful copy, the QR-code button becomes visible so the user
   * can pop up the pre-generated QR code modal to share the link easily.
   */
  (function () {
    var btn = document.getElementById('reveal-copy-btn') as HTMLButtonElement | null;
    if (!btn) return;          // no reveal URL on this page (e.g. the public reveal page itself)

    var qrBtn = document.getElementById('qr-show-btn') as HTMLButtonElement | null;
    var qrModal = document.getElementById('qr-modal') as HTMLElement | null;
    var qrClose = document.getElementById('qr-modal-close') as HTMLButtonElement | null;

    /** Show the copy button only for authenticated users. */
    function showCopyBtn() {
      if (sessionStorage.getItem('auth_token')) {
        btn!.style.display = 'inline-flex';
      }
    }

    btn.addEventListener('click', function () {
      var url = btn!.getAttribute('data-url');
      if (!url) return;
      navigator.clipboard.writeText(url).then(function () {
        var original = btn!.textContent;
        btn!.textContent = '✅ Copied!';
        setTimeout(function () { btn!.textContent = original; }, 2000);
        // Reveal the QR button after a successful copy so the user can share visually.
        if (qrBtn) qrBtn.style.display = 'inline-flex';
      }).catch(function () {
        btn!.textContent = '⚠ Copy failed';
        setTimeout(function () { btn!.textContent = '🔗 Copy Reveal Link'; }, 2000);
      });
    });

    /* QR modal open / close */
    if (qrBtn && qrModal && qrClose) {
      qrBtn.addEventListener('click', function () {
        qrModal!.style.display = 'flex';
        qrClose!.focus();
      });
      qrClose.addEventListener('click', function () {
        qrModal!.style.display = 'none';
      });
      /* Click outside the card to close */
      qrModal.addEventListener('click', function (e) {
        if (e.target === qrModal) qrModal!.style.display = 'none';
      });
      /* Escape key to close */
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && qrModal!.style.display === 'flex') {
          qrModal!.style.display = 'none';
        }
      });
    }

    /* Show if already authenticated on page load */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', showCopyBtn);
    } else {
      showCopyBtn();
    }
    /* Show if the user logs in on this page */
    document.addEventListener('auth:login', showCopyBtn);
  })();
</script>
