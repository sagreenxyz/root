---
/**
 * /reveal/[token] – Daily-expiring public reveal pages.
 *
 * getStaticPaths() runs at BUILD TIME only in Node.js.  It:
 *   1. Reads REVEAL_SECRET from the build environment (never sent to the browser).
 *   2. Computes a per-page, per-day HMAC-SHA256 token for each allowlisted page.
 *   3. Returns one static path per allowlisted page.
 *
 * The resulting pages are fully public (no auth gate).  They expire automatically
 * each nightly rebuild because the token changes with the date; the previous
 * day's URL simply returns 404.
 *
 * Article content is rendered via NursingProcessArticle, which is the same
 * component used by the canonical private page — edits in one place apply to both.
 */
import Layout from '../../layouts/Layout.astro';
import NursingProcessArticle from '../../components/NursingProcessArticle.astro';
import { getDailyRevealToken, REVEALABLE_PAGES, type RevealPage } from '../../lib/revealToken';

export function getStaticPaths() {
  const secret = import.meta.env.REVEAL_SECRET ?? '';
  return REVEALABLE_PAGES.map((page: RevealPage) => ({
    params: { token: getDailyRevealToken(secret, page.slug) },
    props: { page },
  }));
}

const { page } = Astro.props as { page: RevealPage };
---

<Layout title={page.title} protected={false}>

  <!-- Reveal banner -->
  <div style="background:#fef9c3; border:1px solid #fde68a; border-radius:0.65rem; padding:0.85rem 1.1rem; margin-bottom:1.5rem; font-size:0.875rem; color:#713f12; display:flex; align-items:center; gap:0.6rem;">
    <span aria-hidden="true">🔓</span>
    <span><strong>Public reveal link</strong> — This page is temporarily public via a time-limited link. It will expire after the next nightly rebuild.</span>
  </div>

  <!-- Shared article body (sections 1–5, sidebar TOC, Quick Facts, Exam Tips).
       No micro-quiz, no copy button, and no QR code on the public reveal page. -->
  <NursingProcessArticle />

</Layout>
