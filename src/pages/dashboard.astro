---
import Layout from '../layouts/Layout.astro';
// AUTH_HASH is injected by the GitHub Actions build step via the AUTH_HASH secret.
// It must be the SHA-256 hex digest of "<username>:<password>".
const validHash = import.meta.env.AUTH_HASH ?? '';
---

<Layout title="Dashboard – Root" protected={false}>
  <!-- Login panel — shown when not authenticated -->
  <div id="login-panel" style="max-width:400px; margin:4rem auto; background:#fff; border:1px solid #e2e8f0; border-radius:1rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,.06);">
    <div style="text-align:center; margin-bottom:2rem;">
      <div style="font-size:2.5rem; margin-bottom:0.5rem;">🔐</div>
      <h1 style="font-size:1.5rem; font-weight:700;">Sign In</h1>
      <p style="color:#64748b; font-size:0.9rem; margin-top:0.25rem;">Enter your credentials to access the dashboard</p>
    </div>

    <form id="login-form" autocomplete="on">
      <div style="margin-bottom:1rem;">
        <label for="username" style="display:block; font-size:0.875rem; font-weight:500; margin-bottom:0.4rem;">Username</label>
        <input
          id="username"
          name="username"
          type="text"
          autocomplete="username"
          placeholder="Username"
          required
          style="width:100%; padding:0.6rem 0.8rem; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:1rem; outline:none; transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#6366f1'"
          onblur="this.style.borderColor='#e2e8f0'"
        />
      </div>
      <div style="margin-bottom:1.5rem;">
        <label for="password" style="display:block; font-size:0.875rem; font-weight:500; margin-bottom:0.4rem;">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          placeholder="••••••••"
          required
          style="width:100%; padding:0.6rem 0.8rem; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:1rem; outline:none; transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#6366f1'"
          onblur="this.style.borderColor='#e2e8f0'"
        />
      </div>
      <div id="error-msg" style="display:none; color:#dc2626; font-size:0.875rem; margin-bottom:1rem; padding:0.5rem 0.75rem; background:#fef2f2; border-radius:0.4rem; border:1px solid #fecaca;"></div>
      <button
        type="submit"
        style="width:100%; padding:0.75rem; background:#6366f1; color:#fff; border:none; border-radius:0.5rem; font-size:1rem; font-weight:600; cursor:pointer; transition:background 0.2s;"
        onmouseover="this.style.background='#4f46e5'"
        onmouseout="this.style.background='#6366f1'"
      >Sign In</button>
    </form>
    <p style="text-align:center; margin-top:1.5rem; color:#64748b; font-size:0.8rem;">Contact the site administrator if you need access.</p>
  </div>

  <!-- Dashboard panel — shown when authenticated -->
  <div id="dashboard-panel" style="display:none;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
      <div>
        <h1 style="font-size:1.75rem; font-weight:800; margin-bottom:0.25rem;">📊 Dashboard</h1>
        <p style="color:#64748b; font-size:0.9rem;">Welcome back. Here's your overview.</p>
      </div>
      <button
        id="logout-btn"
        style="padding:0.5rem 1.25rem; background:#f1f5f9; color:#1e293b; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:0.875rem; font-weight:600; cursor:pointer; transition:background 0.2s;"
        onmouseover="this.style.background='#e2e8f0'"
        onmouseout="this.style.background='#f1f5f9'"
      >Sign Out</button>
    </div>

    <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); margin-bottom:2rem;">
      {[
        { label: 'Pages', value: '2', icon: '📄' },
        { label: 'Users', value: '1', icon: '👤' },
        { label: 'Status', value: 'Live', icon: '🟢' },
        { label: 'Host', value: 'GitHub Pages', icon: '☁️' },
      ].map(card => (
        <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem;">
          <div style="font-size:1.5rem; margin-bottom:0.5rem;">{card.icon}</div>
          <div style="font-size:0.8rem; color:#64748b; text-transform:uppercase; letter-spacing:0.05em;">{card.label}</div>
          <div style="font-size:1.4rem; font-weight:700; margin-top:0.25rem;">{card.value}</div>
        </div>
      ))}
    </div>

    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.5rem;">
      <h2 style="font-size:1rem; font-weight:600; margin-bottom:1rem;">Session Info</h2>
      <p id="session-user" style="color:#64748b; font-size:0.9rem;"></p>
    </div>
  </div>
</Layout>

<!-- Inject the hash from the AUTH_HASH build secret (no plaintext credentials in source). -->
<script define:vars={{ validHash }}>
  window.__authHash = validHash;
</script>

<script>
  const VALID_HASH: string = (window as any).__authHash ?? '';

  async function sha256(message: string): Promise<string> {
    const msgBuffer = new TextEncoder().encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  function showDashboard(username: string) {
    const loginPanel = document.getElementById('login-panel') as HTMLElement;
    const dashboardPanel = document.getElementById('dashboard-panel') as HTMLElement;
    const sessionUser = document.getElementById('session-user') as HTMLElement;
    if (loginPanel) loginPanel.style.display = 'none';
    if (dashboardPanel) dashboardPanel.style.display = 'block';
    if (sessionUser) sessionUser.textContent = `Logged in as: ${username}`;
  }

  // If already authenticated, show dashboard immediately
  const token = sessionStorage.getItem('auth_token');
  const user = sessionStorage.getItem('auth_user') || 'unknown';
  if (token) {
    showDashboard(user);
  }

  // Login form submission
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const username = (document.getElementById('username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const hash = await sha256(`${username}:${password}`);

    if (hash === VALID_HASH) {
      sessionStorage.setItem('auth_token', hash);
      sessionStorage.setItem('auth_user', username);
      showDashboard(username);
    } else {
      errorMsg.textContent = 'Invalid username or password. Please try again.';
      errorMsg.style.display = 'block';
      (document.getElementById('password') as HTMLInputElement).value = '';
    }
  });

  // Logout button
  const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;
  logoutBtn?.addEventListener('click', () => {
    sessionStorage.removeItem('auth_token');
    sessionStorage.removeItem('auth_user');
    window.location.reload();
  });
</script>
