---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<Layout title="Dashboard – Root" protected={false}>
  <div style="text-align:center; padding:4rem 1rem;">
    <div style="font-size:2rem; margin-bottom:1rem;">↩️</div>
    <p style="color:#64748b;">Redirecting…</p>
  </div>
</Layout>

<!-- Redirect: authenticated users go to private dashboard, others to login -->
<script define:vars={{ base }}>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var nextParam = params.get('next');
    var timeout = params.get('timeout');
    if (sessionStorage.getItem('auth_token')) {
      // Already authenticated — go to private dashboard (or next if valid)
      if (nextParam) {
        try {
          var target = new URL(nextParam, window.location.origin);
          if (target.origin === window.location.origin) {
            window.location.replace(target.pathname + target.search + target.hash);
            return;
          }
        } catch (_) {}
      }
      window.location.replace((base || '') + '/private/dashboard');
    } else {
      // Not authenticated — go to login page, preserving next and timeout params
      var loginUrl = (base || '') + '/login';
      var qs = [];
      if (nextParam) qs.push('next=' + encodeURIComponent(nextParam));
      if (timeout) qs.push('timeout=' + encodeURIComponent(timeout));
      if (qs.length) loginUrl += '?' + qs.join('&');
      window.location.replace(loginUrl);
    }
  })();
</script>
