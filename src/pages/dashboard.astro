---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<Layout title="Dashboard – Root" protected={false}>
  <div style="text-align:center; padding:4rem 1rem;">
    <div style="font-size:2rem; margin-bottom:1rem;">↩️</div>
    <p style="color:#64748b;">Redirecting…</p>
  </div>
</Layout>

<!-- Redirect: authenticated users go to private dashboard, others to login -->
<script define:vars={{ base }}>
  if (sessionStorage.getItem('auth_token')) {
    window.location.replace((base || '') + '/private/dashboard');
  } else {
    // Preserve any ?next= param passed to the old /dashboard route
    var next = new URLSearchParams(window.location.search).get('next');
    var target = (base || '') + '/login';
    if (next) target += '?next=' + encodeURIComponent(next);
    window.location.replace(target);
  }
</script>
