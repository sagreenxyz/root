  @media (max-width: 640px) {
    .slide { padding: 4rem 1.25rem 1.5rem; }
    .two-col, .three-col, .tips-grid { grid-template-columns: 1fr; }
    .slide-main-title { font-size: 1.8rem; }
    .slide-number { top: 3rem; right: 1rem; }
  }
  </style>
</SlidesLayout>
