---
import SlidesLayout from '../../../layouts/SlidesLayout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<SlidesLayout
  title="Patient Hygiene &amp; Personal Care – Slides – D439 Foundations of Nursing"
  protected={true}
  backHref={`${base}/private/d439/hygiene-personal-care`}
  backLabel="← Full Article"
>
  <div class="slides-wrapper">

    <!-- COLUMN 1: Title -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-title">
          <div class="slide-badge">D439 – Foundations of Nursing</div>
          <div class="title-icon">🛁</div>
          <h1 class="slide-main-title">Patient Hygiene &amp; Personal Care</h1>
          <h2 class="slide-subtitle">Oral Care · Tympanic Temperature · Sleep · Sleep Apnea</h2>
          <p class="slide-note">← → Arrow keys or Prev / Next buttons to navigate · ↓ Arrow key for optional detail slides</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 2: Oral Care for Unconscious -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">2 / 7</div>
          <h2 class="slide-heading">🦷 Oral Care — Unconscious Patient</h2>
          <p class="slide-intro">Oral care prevents aspiration pneumonia and ventilator-associated pneumonia (VAP). Frequency: <strong>every 2–4 hours</strong>.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Procedure</h3>
              <ul class="bullet-list">
                <li>Supplies: suction, padded tongue blade, toothbrush, chlorhexidine 0.12%</li>
                <li>Position: <strong>lateral / side-lying</strong>, HOB 30–45°</li>
                <li>Towel under chin; suction PRN</li>
                <li>Use <strong>padded tongue blade</strong> — NEVER fingers</li>
                <li>Brush all tooth surfaces + tongue</li>
                <li>Apply water-soluble lip moisturizer</li>
                <li>Small amounts of solution to prevent aspiration</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Safety Principles</h3>
              <ul class="bullet-list">
                <li><strong>NEVER</strong> tilt head back — aspiration risk</li>
                <li><strong>NEVER</strong> use fingers in mouth — bite risk</li>
                <li>Suction thoroughly before and after</li>
                <li>HOB 30–45° during and after</li>
                <li>Use syringe with small amounts if irrigating</li>
              </ul>
              <div class="callout" style="margin-top:0.75rem;">
                Chlorhexidine 0.12% reduces VAP in mechanically ventilated patients.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 3: Tympanic Temperature -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">3 / 7</div>
          <h2 class="slide-heading">🌡️ Tympanic Temperature</h2>
          <p class="slide-intro">Normal range: <strong>36.0–37.8°C (96.8–100°F)</strong>. Reads approximately <strong>0.5°C higher</strong> than oral temperature.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Procedure</h3>
              <ul class="bullet-list">
                <li>Apply disposable probe cover</li>
                <li><strong>Adults (&gt;3 yr):</strong> pull pinna <strong>UP and BACK</strong></li>
                <li><strong>Children &lt;3 yr:</strong> pull pinna <strong>DOWN and BACK</strong></li>
                <li>Insert snugly toward tympanic membrane</li>
                <li>Press scan button; hold until beep</li>
                <li>Discard probe cover; document site</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Factors Affecting Accuracy</h3>
              <ul class="bullet-list">
                <li>Excessive cerumen (earwax) — falsely low</li>
                <li>Otitis media — may alter reading</li>
                <li>Incorrect positioning of probe</li>
                <li>Patient recently lying on that ear — wait <strong>2–3 minutes</strong></li>
                <li>Improper canal straightening</li>
              </ul>
              <div class="callout" style="margin-top:0.75rem;">
                Same ear canal direction rule applies to ear drop administration.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 4: Back Rub & Nocturia -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">4 / 7</div>
          <h2 class="slide-heading">🤲 Back Rub &amp; Nocturia</h2>
          <p class="slide-intro">Back rub promotes relaxation, circulation, and sleep while providing an opportunity for skin assessment.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Back Rub Procedure</h3>
              <ul class="bullet-list">
                <li>Position: prone or lateral</li>
                <li>Warm lotion before applying</li>
                <li><strong>Effleurage</strong> — long gliding strokes (start &amp; end)</li>
                <li><strong>Petrissage</strong> — kneading at shoulders</li>
                <li><strong>Friction</strong> — circular at vertebral border of scapulae</li>
                <li><strong>NEVER</strong> massage reddened bony prominences</li>
                <li>Avoid: thrombophlebitis, fractures, fresh surgery, breakdown areas</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Nocturia Management</h3>
              <ul class="bullet-list">
                <li>Nocturia = waking <strong>≥1×/night</strong> to void</li>
                <li><strong>Causes:</strong> BPH, OAB, UTI, diabetes, heart failure, diuretics</li>
                <li>Limit fluids <strong>2–3 hours</strong> before bed</li>
                <li>No caffeine or alcohol in evenings</li>
                <li>Time diuretics for morning administration</li>
                <li>Void before bedtime</li>
                <li>Nightlight + call light within reach (fall prevention)</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 5: Sleep Promotion -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">5 / 7</div>
          <h2 class="slide-heading">😴 Sleep Promotion</h2>
          <p class="slide-intro">Non-pharmacological interventions <strong>first</strong>. Hospital environments are inherently disruptive to normal sleep cycles.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Sleep Hygiene Education</h3>
              <ul class="bullet-list">
                <li>Consistent sleep/wake schedule</li>
                <li>Use bed only for sleep (not phone/TV)</li>
                <li>Comfortable temperature (~68°F)</li>
                <li>Limit screen time — blue light suppresses melatonin</li>
                <li>No caffeine or alcohol in evening</li>
                <li>Warm bath or back rub before bed</li>
                <li>Warm milk or herbal tea</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Hospital-Specific Interventions</h3>
              <ul class="bullet-list">
                <li><strong>Cluster nursing care</strong> — protect 90-min uninterrupted sleep cycles</li>
                <li>Dim lights at night; reduce overhead noise</li>
                <li>Progressive muscle relaxation</li>
                <li>4-7-8 breathing technique</li>
                <li>Guided imagery</li>
                <li>Control pain before bedtime</li>
                <li>Earplugs or sleep mask if needed</li>
              </ul>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 Clustering care = group assessments and medications together to allow 90-minute uninterrupted blocks.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 6: Sleep Apnea -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">6 / 7</div>
          <h2 class="slide-heading">😤 Sleep Apnea</h2>
          <p class="slide-intro">Repeated episodes of upper airway obstruction; apnea ≥10 seconds. OSA is the most common type. High risk postoperatively.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Signs &amp; Risk Factors</h3>
              <ul class="bullet-list">
                <li><strong>S/S:</strong> loud snoring, witnessed apnea, excessive daytime sleepiness, morning headaches, nocturia</li>
                <li><strong>Risk factors:</strong> obesity (BMI &gt;30), male, age &gt;40, large neck (&gt;17" men, &gt;16" women), smoking, alcohol</li>
                <li><strong>Diagnosis:</strong> polysomnography, STOP-BANG questionnaire</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Nursing Management</h3>
              <ul class="bullet-list">
                <li>Ensure <strong>CPAP/BiPAP</strong> accompanies patient to hospital</li>
                <li>HOB 30–45° during sleep</li>
                <li>Continuous SpO₂ monitoring</li>
                <li>Lateral positioning preferred</li>
                <li>Avoid sedatives and opioids without monitoring</li>
                <li>Weight loss education</li>
              </ul>
            </div>
          </div>
          <div class="callout">
            🚨 Sleep apnea + post-op opioids = <strong>HIGH RISK</strong> for respiratory depression. Monitor closely.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 7: Exam Tips -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-exam">
          <div class="slide-number">7 / 7</div>
          <h2 class="slide-heading">📝 Exam Tips &amp; Key Points</h2>
          <div class="tips-grid">
            <div class="tip-card"><span class="tip-icon">🦷</span><span class="tip-text">Use padded tongue blade for unconscious oral care — NEVER fingers</span></div>
            <div class="tip-card"><span class="tip-icon">👂</span><span class="tip-text">Adult ear: pull pinna UP and BACK; Child &lt;3 yr: DOWN and BACK</span></div>
            <div class="tip-card"><span class="tip-icon">🚫</span><span class="tip-text">Do NOT massage reddened bony prominences — causes tissue damage</span></div>
            <div class="tip-card"><span class="tip-icon">😴</span><span class="tip-text">Cluster nursing care to protect 90-minute sleep cycles</span></div>
            <div class="tip-card"><span class="tip-icon">😤</span><span class="tip-text">CPAP/BiPAP must accompany patient when admitted to hospital</span></div>
            <div class="tip-card"><span class="tip-icon">🚨</span><span class="tip-text">Sleep apnea + opioids post-op = HIGH respiratory depression risk</span></div>
            <div class="tip-card"><span class="tip-icon">🌡️</span><span class="tip-text">Tympanic temperature reads ~0.5°C HIGHER than oral temperature</span></div>
            <div class="tip-card"><span class="tip-icon">💧</span><span class="tip-text">Nocturia: no fluids 2–3h before bed; time diuretics in the morning</span></div>
          </div>
          <div style="margin-top:1.5rem; text-align:center;">
            <a href={`${base}/private/d439/hygiene-personal-care`} class="article-link">← Full Article</a>
            <a href={`${base}/private/d439`} class="article-link article-link-ghost">D439 Home</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>
  .slide { padding: 4rem 3rem 2rem; }
  .slide.optional { padding-top: 5rem; }
  .opt-inner { max-width: 900px; width: 100%; margin: 0 auto; }
  .slide-number { position: absolute; top: 3.5rem; right: 1.5rem; font-size: 0.75rem; color: #94a3b8; font-weight: 600; }
  .slide-title { align-items: center; justify-content: center; text-align: center; background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%); }
  .slide-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #6366f1; background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 0.35rem; padding: 0.2rem 0.55rem; margin-bottom: 1rem; }
  .title-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .slide-main-title { font-size: 2.4rem; font-weight: 800; color: #1e293b; line-height: 1.15; margin-bottom: 0.25rem; }
  .slide-subtitle { font-size: 1.5rem; font-weight: 700; color: #6366f1; margin-bottom: 1.5rem; }
  .slide-note { font-size: 0.78rem; color: #94a3b8; }
  .slide-heading { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center; gap: 0.5rem; }
  .step-letter { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; background: #6366f1; color: #fff; border-radius: 50%; font-size: 1rem; font-weight: 800; flex-shrink: 0; }
  .slide-intro { font-size: 0.95rem; color: #475569; line-height: 1.6; margin-bottom: 1rem; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; flex: 1; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; flex: 1; }
  .col-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.6rem; padding: 1rem; }
  .col-card-sm { padding: 0.85rem; }
  .col-title { font-size: 0.875rem; font-weight: 700; color: #6366f1; margin-bottom: 0.5rem; }
  .col-title-sm { font-size: 0.8rem; }
  .col-body { font-size: 0.82rem; color: #374151; margin-bottom: 0.4rem; }
  .col-example { font-size: 0.78rem; color: #64748b; font-style: italic; }
  .bullet-list { font-size: 0.85rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; margin: 0; }
  .bullet-list li { margin-bottom: 0.25rem; }
  .callout { background: #eff6ff; border-left: 4px solid #bfdbfe; border-radius: 0.5rem; padding: 0.75rem 1rem; font-size: 0.85rem; color: #1e3a5f; line-height: 1.6; margin-top: auto; }
  .callout-tip { background: #eef2ff; border-left-color: #a5b4fc; color: #312e81; }
  .optional-hint { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: #94a3b8; margin-top: auto; padding-top: 0.5rem; }
  .back-hint { position: absolute; top: 3rem; left: 1.5rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: #94a3b8; }
  .optional-hint .arrow, .back-hint .arrow { font-size: 1rem; }
  .overview-grid { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; margin-bottom: 0.75rem; }
  .overview-row { display: flex; align-items: flex-start; gap: 0.75rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.6rem 0.85rem; font-size: 0.875rem; color: #374151; }
  .step-badge { flex-shrink: 0; width: 1.75rem; height: 1.75rem; background: #6366f1; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem; }
  .step-q { display: block; font-size: 0.78rem; color: #64748b; font-style: italic; margin-top: 0.1rem; }
  .slide-exam { background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 100%); }
  .tips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; flex: 1; }
  .tip-card { display: flex; align-items: flex-start; gap: 0.6rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 0.55rem; padding: 0.65rem 0.85rem; }
  .tip-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.05rem; }
  .tip-text { font-size: 0.84rem; color: #374151; line-height: 1.45; }
  .article-link { display: inline-flex; align-items: center; padding: 0.55rem 1.1rem; background: #6366f1; color: #fff; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; text-decoration: none; margin: 0 0.25rem; }
  .article-link:hover { background: #4f46e5; }
  .article-link-ghost { background: #f1f5f9; color: #1e293b; border: 1px solid #e2e8f0; }
  .article-link-ghost:hover { background: #e2e8f0; }
  @media (max-width: 640px) {
    .slide { padding: 4rem 1.25rem 1.5rem; }
    .two-col, .three-col, .tips-grid { grid-template-columns: 1fr; }
    .slide-main-title { font-size: 1.8rem; }
    .slide-number { top: 3rem; right: 1rem; }
  }
  </style>
</SlidesLayout>
