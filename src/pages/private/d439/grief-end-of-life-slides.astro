---
import SlidesLayout from '../../../layouts/SlidesLayout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<SlidesLayout
  title="Grief, Hospice &amp; Palliative Care – Slides – D439 Foundations of Nursing"
  protected={true}
  backHref={`${base}/private/d439/grief-end-of-life`}
  backLabel="← Full Article"
>
  <div class="slides-wrapper">

    <!-- COLUMN 1: Title -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-title">
          <div class="slide-badge">D439 – Foundations of Nursing</div>
          <div class="title-icon">🕊️</div>
          <h1 class="slide-main-title">Grief, Hospice &amp; Palliative Care</h1>
          <h2 class="slide-subtitle">Kübler-Ross · DABDA · Hospice vs Palliative · Empathy</h2>
          <p class="slide-note">← → Arrow keys or Prev / Next buttons to navigate · ↓ Arrow key for optional detail slides</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 2: Kübler-Ross DABDA -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">2 / 6</div>
          <h2 class="slide-heading">💛 Kübler-Ross — DABDA Stages</h2>
          <p class="slide-intro">Five stages of grief — <strong>NOT linear</strong>. Patients may move between stages or experience multiple simultaneously.</p>
          <div class="overview-grid">
            <div class="overview-row">
              <span class="step-badge">D</span>
              <div><strong>Denial</strong> — protective buffer; allow processing<span class="step-q">Don't confront unless denial blocks necessary care</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">A</span>
              <div><strong>Anger</strong> — may be directed at team, God, or family<span class="step-q">Don't take personally; validate the feeling</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">B</span>
              <div><strong>Bargaining</strong> — seeking control; "if only..."<span class="step-q">Support hope; do not make promises</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">D</span>
              <div><strong>Depression</strong> — reactive or preparatory sadness<span class="step-q">Allow sadness; sit with patient; assess for clinical depression</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">A</span>
              <div><strong>Acceptance</strong> — peaceful acknowledgment of reality<span class="step-q">Support; facilitate unfinished business; respect wishes</span></div>
            </div>
          </div>
          <div class="optional-hint"><span class="arrow">↓</span><span>Other grief models &amp; anticipatory grief</span></div>
        </div>
        <div class="slide optional">
          <div class="back-hint"><span class="arrow">↑</span><span>Back to DABDA</span></div>
          <div class="opt-inner">
            <h2 class="slide-heading">Other Grief Models &amp; Special Grief Types</h2>
            <div class="two-col">
              <div class="col-card">
                <h3 class="col-title">Other Models</h3>
                <ul class="bullet-list">
                  <li><strong>Worden's 4 Tasks:</strong> Accept reality, Work through pain, Adjust to world, Maintain connection while moving forward</li>
                  <li><strong>Rando's 6 R's:</strong> Recognize, React, Recollect, Relinquish, Readjust, Reinvest</li>
                  <li><strong>Bowlby:</strong> Numbness → Yearning → Disorganization → Reorganization</li>
                </ul>
              </div>
              <div class="col-card">
                <h3 class="col-title">Special Grief Types</h3>
                <ul class="bullet-list">
                  <li><strong>Anticipatory grief</strong> — grief before the death occurs; normal and healthy</li>
                  <li><strong>Complicated (prolonged) grief</strong> — lasting &gt;12 months; requires referral to mental health</li>
                  <li><strong>Disenfranchised grief</strong> — not socially recognized (pet loss, miscarriage)</li>
                </ul>
                <div class="callout" style="margin-top:0.75rem;">
                  Complicated grief = refer to grief counselor or mental health professional.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 3: Hospice vs Palliative Care -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">3 / 6</div>
          <h2 class="slide-heading">🏥 Hospice vs. Palliative Care</h2>
          <p class="slide-intro"><strong>"All hospice is palliative care, but not all palliative care is hospice."</strong></p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Palliative Care</h3>
              <ul class="bullet-list">
                <li><strong>Eligibility:</strong> any serious illness, any stage</li>
                <li><strong>Curative treatment:</strong> may continue</li>
                <li><strong>Focus:</strong> symptom management + QOL</li>
                <li><strong>Setting:</strong> hospital, home, outpatient</li>
                <li><strong>Team:</strong> interprofessional</li>
                <li>Family included in care</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Hospice Care</h3>
              <ul class="bullet-list">
                <li><strong>Eligibility:</strong> terminal prognosis ≤6 months</li>
                <li><strong>Curative treatment:</strong> stopped or declined</li>
                <li><strong>Focus:</strong> comfort + dignified death</li>
                <li><strong>Setting:</strong> home, hospice facility, SNF</li>
                <li><strong>Team:</strong> adds volunteers + bereavement counselors</li>
                <li>Bereavement support up to <strong>13 months</strong> after death</li>
              </ul>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 Hospice benefit under Medicare requires MD certification that life expectancy ≤6 months if disease runs its normal course.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 4: Communicating with Grieving Family -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">4 / 6</div>
          <h2 class="slide-heading">🤝 Communicating with Grieving Family</h2>
          <p class="slide-intro">Presence and compassionate listening are the most powerful nursing interventions with grieving families.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">What TO DO</h3>
              <ul class="bullet-list">
                <li>Sit down; be fully present</li>
                <li>Use the deceased's name</li>
                <li>Acknowledge the loss directly</li>
                <li>Validate all feelings expressed</li>
                <li>Listen actively, allow silence</li>
                <li>Explain what happened in simple terms</li>
                <li>Allow family to see the body</li>
                <li>Provide specific bereavement resources</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">What NOT to Say</h3>
              <ul class="bullet-list">
                <li>"I know how you feel"</li>
                <li>"Everything happens for a reason"</li>
                <li>"They're in a better place now"</li>
                <li>"At least they didn't suffer"</li>
                <li>"You need to stay strong"</li>
                <li>"Let me know if you need anything" (too vague)</li>
                <li>"God needed another angel"</li>
              </ul>
            </div>
          </div>
          <div class="callout">
            🤍 Offer specific help: "I'll call the chaplain for you" instead of open-ended offers.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 5: Empathy -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">5 / 6</div>
          <h2 class="slide-heading">💙 Empathy in Nursing Practice</h2>
          <p class="slide-intro"><strong>Empathy</strong> = understanding and sharing another's feelings; stepping into their perspective. Different from <strong>sympathy</strong> (feeling sorry FOR someone — creates distance).</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Wiseman's 4 Components</h3>
              <ul class="bullet-list">
                <li><strong>Perspective-taking</strong> — see the world through their eyes</li>
                <li><strong>Non-judgment</strong> — withhold evaluation</li>
                <li><strong>Recognizing emotion</strong> — identify what they're feeling</li>
                <li><strong>Communicating recognition</strong> — reflect it back</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Empathic Responses — Examples</h3>
              <ul class="bullet-list">
                <li>"Scared about surgery" → "That's completely understandable. What worries you most?"</li>
                <li>Patient crying → sit quietly, hand on shoulder (if welcome)</li>
                <li>Family frustration → "I understand you're frustrated. Let's talk about what you're seeing."</li>
                <li>New diagnosis → "This is a lot to take in. Let's go through it one step at a time."</li>
              </ul>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 Empathy is a skill — it can be learned and practiced. Silence and presence are empathic actions.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 6: Exam Tips -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-exam">
          <div class="slide-number">6 / 6</div>
          <h2 class="slide-heading">📝 Exam Tips &amp; Key Points</h2>
          <div class="tips-grid">
            <div class="tip-card"><span class="tip-icon">💛</span><span class="tip-text">DABDA stages are NOT linear — patients move between stages</span></div>
            <div class="tip-card"><span class="tip-icon">📅</span><span class="tip-text">Anticipatory grief before death is NORMAL and healthy</span></div>
            <div class="tip-card"><span class="tip-icon">⚠️</span><span class="tip-text">Complicated grief lasting &gt;12 months → refer to counseling</span></div>
            <div class="tip-card"><span class="tip-icon">🏥</span><span class="tip-text">Hospice eligibility = prognosis ≤6 months; curative treatment stopped</span></div>
            <div class="tip-card"><span class="tip-icon">💊</span><span class="tip-text">Palliative = alongside any treatment, at any stage of serious illness</span></div>
            <div class="tip-card"><span class="tip-icon">🚫</span><span class="tip-text">NEVER say "I know how you feel" to grieving patients or families</span></div>
            <div class="tip-card"><span class="tip-icon">💙</span><span class="tip-text">Empathy ≠ sympathy; empathy connects, sympathy creates distance</span></div>
            <div class="tip-card"><span class="tip-icon">🤍</span><span class="tip-text">Sitting silently with patient — presence IS the intervention</span></div>
          </div>
          <div style="margin-top:1.5rem; text-align:center;">
            <a href={`${base}/private/d439/grief-end-of-life`} class="article-link">← Full Article</a>
            <a href={`${base}/private/d439`} class="article-link article-link-ghost">D439 Home</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>
  .slide { padding: 4rem 3rem 2rem; }
  .slide.optional { padding-top: 5rem; }
  .opt-inner { max-width: 900px; width: 100%; margin: 0 auto; }
  .slide-number { position: absolute; top: 3.5rem; right: 1.5rem; font-size: 0.75rem; color: #94a3b8; font-weight: 600; }
  .slide-title { align-items: center; justify-content: center; text-align: center; background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%); }
  .slide-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #6366f1; background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 0.35rem; padding: 0.2rem 0.55rem; margin-bottom: 1rem; }
  .title-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .slide-main-title { font-size: 2.4rem; font-weight: 800; color: #1e293b; line-height: 1.15; margin-bottom: 0.25rem; }
  .slide-subtitle { font-size: 1.5rem; font-weight: 700; color: #6366f1; margin-bottom: 1.5rem; }
  .slide-note { font-size: 0.78rem; color: #94a3b8; }
  .slide-heading { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center; gap: 0.5rem; }
  .step-letter { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; background: #6366f1; color: #fff; border-radius: 50%; font-size: 1rem; font-weight: 800; flex-shrink: 0; }
  .slide-intro { font-size: 0.95rem; color: #475569; line-height: 1.6; margin-bottom: 1rem; }
