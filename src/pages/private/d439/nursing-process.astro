      { label: 'A', text: 'Focused assessment' },
      { label: 'B', text: 'Emergency assessment' },
      { label: 'C', text: 'Time-lapsed reassessment' },
      { label: 'D', text: 'Initial (admission) assessment' },
    ],
    correct: ['D'],
    rationale: 'The initial (admission) assessment is a comprehensive database collected on first contact with the patient to establish a baseline. A focused assessment targets a specific problem; emergency assessment addresses life-threatening priorities; time-lapsed reassessment compares current status to a prior baseline.',
  },
  {
    n: 11,
    type: 'single',
    stem: 'During the assessment interview, the nurse says: "When you say you feel \'awful,\' can you describe specifically what you are experiencing?" This technique is called:',
    options: [
      { label: 'A', text: 'Reflection' },
      { label: 'B', text: 'Clarification' },
      { label: 'C', text: 'Therapeutic silence' },
      { label: 'D', text: 'Leading questioning' },
    ],
    correct: ['B'],
    rationale: 'Clarification is used when a patient\'s statement is vague or ambiguous. The nurse asks for clarification to ensure accurate data collection and to avoid misinterpreting the patient\'s experience.',
  },
  {
    n: 12,
    type: 'sata',
    stem: 'Which of the following statements about the nursing process are <strong>correct</strong>? <strong>(Select all that apply.)</strong>',
    options: [
      { label: 'A', text: 'The nursing process is linear and ends after evaluation.' },
      { label: 'B', text: 'Assessment is the foundation upon which all other steps depend.' },
      { label: 'C', text: 'A nursing diagnosis describes the human response to a health problem, within nursing scope of practice.' },
      { label: 'D', text: 'Goals written during planning should be nurse-centred, describing what the nurse will do.' },
      { label: 'E', text: 'Evaluation determines whether expected outcomes have been achieved and may lead to revision of the care plan.' },
    ],
    correct: ['B', 'C', 'E'],
    rationale: 'The nursing process is cyclical, not linear (A is false). Goals must be patient-centred, not nurse-centred (D is false). Assessment is foundational (B), nursing diagnoses address human responses (C), and evaluation measures goal achievement and drives plan revision (E).',
  },
];

function mqRenderQuestion(q) {
  const id = 'mq' + q.n;
  const isSATA = q.type === 'sata';
  const inputType = isSATA ? 'checkbox' : 'radio';
  let optionsHtml = '';
  q.options.forEach(opt => {
    optionsHtml += `
      <label class="mq-opt" id="${id}_opt${opt.label}" style="display:flex;align-items:flex-start;gap:0.6rem;padding:0.55rem 0.75rem;border-radius:0.5rem;border:1.5px solid #e2e8f0;margin-bottom:0.45rem;cursor:pointer;transition:border-color 0.15s;">
        <input type="${inputType}" name="${id}" value="${opt.label}" style="margin-top:0.2rem;flex-shrink:0;accent-color:#6366f1;" />
        <span><strong>${opt.label}.</strong> ${opt.text}</span>
      </label>`;
  });
  return `
    <div class="mq-card" id="mqcard_${id}" style="background:#fff;border:1px solid #e2e8f0;border-radius:0.75rem;padding:1.25rem 1.5rem;margin-bottom:1rem;">
      <p style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#6366f1;margin-bottom:0.4rem;">Question ${q.n}${isSATA ? ' — Select all that apply' : ''}</p>
      <p style="font-size:0.925rem;line-height:1.7;color:#1e293b;margin-bottom:0.9rem;">${q.stem}</p>
      <div>${optionsHtml}</div>
      <div class="mq-rat" id="mqrat_${id}" style="display:none;margin-top:0.9rem;padding:0.7rem 0.9rem;border-radius:0.45rem;font-size:0.85rem;line-height:1.6;"></div>
    </div>`;
}

function mqRender() {
  document.getElementById('mq-form').innerHTML = MQ_QUESTIONS.map(mqRenderQuestion).join('');
}

function mqSubmit() {
  let total = 0, correct = 0;
  MQ_QUESTIONS.forEach(q => {
    const id = 'mq' + q.n;
    const given = [...document.querySelectorAll(`input[name="${id}"]:checked`)].map(i => i.value).sort();
    const expected = q.correct.slice().sort();
    const isCorrect = JSON.stringify(given) === JSON.stringify(expected);
    if (isCorrect) correct++;
    total++;

    const card = document.getElementById('mqcard_' + id);
    card.querySelectorAll('.mq-opt').forEach(lbl => {
      const inp = lbl.querySelector('input');
      if (!inp) return;
      inp.disabled = true;
      const val = inp.value;
      if (expected.includes(val) && given.includes(val)) {
        lbl.style.borderColor = '#16a34a'; lbl.style.background = '#f0fdf4';
      } else if (expected.includes(val) && !given.includes(val)) {
        lbl.style.borderColor = '#d97706'; lbl.style.background = '#fffbeb';
      } else if (!expected.includes(val) && given.includes(val)) {
        lbl.style.borderColor = '#dc2626'; lbl.style.background = '#fef2f2';
      }
    });
    card.style.borderColor = isCorrect ? '#bbf7d0' : '#fecaca';

    const rat = document.getElementById('mqrat_' + id);
    rat.style.display = 'block';
    rat.style.background = isCorrect ? '#f0fdf4' : '#fef2f2';
    rat.style.borderLeft = '4px solid ' + (isCorrect ? '#16a34a' : '#dc2626');
    rat.style.color = isCorrect ? '#166534' : '#991b1b';
    rat.innerHTML = '<strong>' + (isCorrect ? '✓ Correct' : '✗ Incorrect') + '</strong> — ' + q.rationale;
  });

  const pct = Math.round((correct / total) * 100);
  const banner = document.getElementById('mq-score-banner');
  document.getElementById('mq-score-text').textContent = correct + ' / ' + total + ' correct (' + pct + '%)';
  document.getElementById('mq-score-sub').textContent =
    pct >= 80 ? '🎉 Excellent! You have a strong grasp of the nursing process.' :
    pct >= 60 ? '📚 Good effort — review the highlighted rationales.' :
    '🔍 Review the ADPIE sections above before retrying.';
  banner.style.display = 'block';
  banner.style.background = pct >= 80 ? '#f0fdf4' : pct >= 60 ? '#fffbeb' : '#fef2f2';
  banner.style.border = '1px solid ' + (pct >= 80 ? '#bbf7d0' : pct >= 60 ? '#fde68a' : '#fecaca');
  document.getElementById('mq-score-text').style.color = pct >= 80 ? '#166534' : pct >= 60 ? '#92400e' : '#991b1b';
  document.getElementById('mq-score-sub').style.color = pct >= 80 ? '#15803d' : pct >= 60 ? '#b45309' : '#b91c1c';
  banner.scrollIntoView({ behavior: 'smooth' });

  document.getElementById('mq-submit-btn').style.display = 'none';
  document.getElementById('mq-reset-btn').style.display = 'inline-block';
}

function mqReset() {
  document.getElementById('mq-score-banner').style.display = 'none';
  document.getElementById('mq-submit-btn').style.display = 'inline-block';
  document.getElementById('mq-reset-btn').style.display = 'none';
  mqRender();
  document.getElementById('microquiz').scrollIntoView({ behavior: 'smooth' });
}

document.addEventListener('DOMContentLoaded', mqRender);
</script>
