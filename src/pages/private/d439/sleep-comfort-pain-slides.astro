---
import SlidesLayout from '../../../layouts/SlidesLayout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<SlidesLayout
  title="Sleep, Comfort &amp; Pain Management – Slides – D439 Foundations of Nursing"
  protected={true}
  backHref={`${base}/private/d439/sleep-comfort-pain`}
  backLabel="← Full Article"
>
  <div class="slides-wrapper">

    <!-- COLUMN 1: Title -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-title">
          <div class="slide-badge">D439 – Foundations of Nursing</div>
          <div class="title-icon">😴</div>
          <h1 class="slide-main-title">Sleep, Comfort &amp; Pain Management</h1>
          <h2 class="slide-subtitle">Pain Assessment · Guided Imagery · Maslow · Hyperkalemia</h2>
          <p class="slide-note">← → Arrow keys or Prev / Next buttons to navigate · ↓ Arrow key for optional detail slides</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 2: Guided Imagery -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">2 / 7</div>
          <h2 class="slide-heading">🧘 Guided Imagery</h2>
          <p class="slide-intro">Mind-body technique using directed visualization to reduce pain, anxiety, and stress. Activates the <strong>parasympathetic nervous system</strong>.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Procedure</h3>
              <ul class="bullet-list">
                <li>Quiet, comfortable environment</li>
                <li>Close eyes; deep, slow breaths</li>
                <li>Guide patient to a peaceful, safe place</li>
                <li>Engage all five senses in description</li>
                <li>Duration: 10–20 minutes</li>
                <li>Document patient response</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Uses &amp; Contraindications</h3>
              <ul class="bullet-list">
                <li><strong>Uses:</strong> preop anxiety, chronic pain, insomnia, chemo nausea, labor pain</li>
                <li><strong>Physiological effect:</strong> ↓ cortisol, ↓ catecholamines, ↓ HR/BP/RR</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">Contraindications</h3>
              <ul class="bullet-list">
                <li>Psychosis or difficulty distinguishing fantasy from reality</li>
                <li>Active suicidal ideation</li>
                <li>Severe cognitive impairment</li>
              </ul>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 Guided imagery is a non-pharmacological intervention — always consider before adding medications.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 3: Pain Assessment -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">3 / 7</div>
          <h2 class="slide-heading">😣 Pain Assessment (PQRSTU)</h2>
          <p class="slide-intro"><strong>Self-report is the most reliable indicator of pain.</strong> Use validated scales matched to the patient's age and cognitive status.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">PQRSTU Framework</h3>
              <ul class="bullet-list">
                <li><strong>P</strong> — Provokes / Palliates</li>
                <li><strong>Q</strong> — Quality (sharp, dull, burning, throbbing)</li>
                <li><strong>R</strong> — Region / Radiation</li>
                <li><strong>S</strong> — Severity 0–10</li>
                <li><strong>T</strong> — Timing (constant vs. intermittent, onset)</li>
                <li><strong>U</strong> — Understanding / Impact on function</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Scales by Population</h3>
              <ul class="bullet-list">
                <li><strong>NRS 0–10</strong> — adults ≥8 years, cognitively intact</li>
                <li><strong>FACES</strong> — children 3–7 years</li>
                <li><strong>FLACC</strong> — infants/preverbal (score 0–10)</li>
                <li><strong>CPOT</strong> — critical care / nonverbal</li>
                <li><strong>PAINAD</strong> — dementia patients</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">Reassessment Timing</h3>
              <ul class="bullet-list">
                <li>30–60 min after non-pharmacological</li>
                <li>15–30 min after IV medications</li>
                <li>60 min after oral or IM medications</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 4: Pain Management -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">4 / 7</div>
          <h2 class="slide-heading">💊 Pain Management</h2>
          <p class="slide-intro"><strong>Multimodal analgesia = gold standard.</strong> Combines pharmacological and non-pharmacological approaches.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">WHO Analgesic Ladder</h3>
              <ul class="bullet-list">
                <li><strong>Step 1</strong> — Non-opioids: acetaminophen, NSAIDs (mild–mod pain)</li>
                <li><strong>Step 2</strong> — Mild opioids: codeine, tramadol (mod pain)</li>
                <li><strong>Step 3</strong> — Strong opioids: morphine, oxycodone (severe pain)</li>
                <li><strong>Adjuvants</strong> at any step: gabapentin, duloxetine (neuropathic)</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Non-Pharmacological</h3>
              <ul class="bullet-list">
                <li>Cold/heat application</li>
                <li>Repositioning, splinting</li>
                <li>Massage therapy</li>
                <li>TENS (transcutaneous electrical nerve stimulation)</li>
                <li>Distraction, music, guided imagery</li>
                <li>Deep breathing, relaxation</li>
              </ul>
            </div>
          </div>
          <div class="callout">
            🚨 <strong>Opioid Safety:</strong> Hold if RR &lt;12; monitor sedation level; keep naloxone (Narcan) available at bedside.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 5: Maslow's Hierarchy -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">5 / 7</div>
          <h2 class="slide-heading">🔺 Maslow's Hierarchy of Needs</h2>
          <p class="slide-intro">Guides clinical priority-setting. <strong>Always address physiological needs first</strong> — a patient in respiratory distress cannot learn.</p>
          <div class="overview-grid">
            <div class="overview-row">
              <span class="step-badge">1</span>
              <div><strong>Physiological</strong> — ABC, food, water, sleep, elimination<span class="step-q">ALWAYS first priority in acute care</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">2</span>
              <div><strong>Safety</strong> — fall prevention, infection control, medication safety<span class="step-q">Second priority after physiological</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">3</span>
              <div><strong>Love/Belonging</strong> — therapeutic relationship, family connection<span class="step-q">Therapeutic communication, family visitation</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">4</span>
              <div><strong>Esteem</strong> — promote independence, involve in decisions<span class="step-q">Shared decision-making, preserve dignity</span></div>
            </div>
            <div class="overview-row">
              <span class="step-badge">5</span>
              <div><strong>Self-Actualization</strong> — meaning, purpose, growth<span class="step-q">Lowest priority in acute illness</span></div>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 When asked "what do you do first?" — always look for the physiological/safety need.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 6: Hyperkalemia -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">6 / 7</div>
          <h2 class="slide-heading">⚡ Hyperkalemia</h2>
          <p class="slide-intro">K+ &gt;5.0 mEq/L (normal 3.5–5.0). Most dangerous complication = fatal cardiac dysrhythmias.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">EKG Changes (in order)</h3>
              <ul class="bullet-list">
                <li><strong>Peaked T waves</strong> — EARLIEST sign</li>
                <li>Prolonged PR interval</li>
                <li>Widened QRS complex</li>
                <li>Sine wave pattern</li>
                <li>Ventricular fibrillation → death</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">Other S/S</h3>
              <ul class="bullet-list">
                <li>Muscle weakness, cramps, paresthesias</li>
                <li>GI: nausea, vomiting, diarrhea</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Management (Priority Order)</h3>
              <ul class="bullet-list">
                <li><strong>Calcium gluconate IV</strong> — stabilizes cardiac membrane (immediate, 1st line)</li>
                <li><strong>Insulin + dextrose</strong> — shifts K+ into cells</li>
                <li><strong>Sodium bicarbonate</strong> — alkalosis shifts K+ into cells</li>
                <li><strong>Kayexalate</strong> — removes K+ from body</li>
                <li><strong>Furosemide</strong> — promotes renal excretion</li>
                <li><strong>Dialysis</strong> — severe/refractory cases</li>
              </ul>
            </div>
          </div>
          <div class="callout">
            🔌 Continuous cardiac monitoring required. Hold K+ supplements; avoid K-sparing diuretics.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 7: Exam Tips -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-exam">
          <div class="slide-number">7 / 7</div>
          <h2 class="slide-heading">📝 Exam Tips &amp; Key Points</h2>
          <div class="tips-grid">
            <div class="tip-card"><span class="tip-icon">🧘</span><span class="tip-text">Guided imagery is contraindicated in patients with psychosis</span></div>
            <div class="tip-card"><span class="tip-icon">😣</span><span class="tip-text">Pain is subjective — ALWAYS believe the patient's self-report</span></div>
            <div class="tip-card"><span class="tip-icon">💊</span><span class="tip-text">Multimodal analgesia = gold standard for pain management</span></div>
            <div class="tip-card"><span class="tip-icon">🚨</span><span class="tip-text">Hold opioids if RR &lt;12; keep naloxone at bedside</span></div>
            <div class="tip-card"><span class="tip-icon">🔺</span><span class="tip-text">Physiological needs ALWAYS first (Maslow Level 1)</span></div>
            <div class="tip-card"><span class="tip-icon">⚡</span><span class="tip-text">Peaked T waves = earliest EKG sign of hyperkalemia</span></div>
            <div class="tip-card"><span class="tip-icon">💉</span><span class="tip-text">Calcium gluconate = first-line emergency treatment for hyperkalemia</span></div>
            <div class="tip-card"><span class="tip-icon">📊</span><span class="tip-text">WHO Ladder: Step 1=non-opioids, Step 2=mild opioids, Step 3=strong opioids</span></div>
          </div>
          <div style="margin-top:1.5rem; text-align:center;">
            <a href={`${base}/private/d439/sleep-comfort-pain`} class="article-link">← Full Article</a>
            <a href={`${base}/private/d439`} class="article-link article-link-ghost">D439 Home</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>
  .slide { padding: 4rem 3rem 2rem; }
  .slide.optional { padding-top: 5rem; }
  .opt-inner { max-width: 900px; width: 100%; margin: 0 auto; }
  .slide-number { position: absolute; top: 3.5rem; right: 1.5rem; font-size: 0.75rem; color: #94a3b8; font-weight: 600; }
  .slide-title { align-items: center; justify-content: center; text-align: center; background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%); }
  .slide-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #6366f1; background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 0.35rem; padding: 0.2rem 0.55rem; margin-bottom: 1rem; }
  .title-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .slide-main-title { font-size: 2.4rem; font-weight: 800; color: #1e293b; line-height: 1.15; margin-bottom: 0.25rem; }
  .slide-subtitle { font-size: 1.5rem; font-weight: 700; color: #6366f1; margin-bottom: 1.5rem; }
  .slide-note { font-size: 0.78rem; color: #94a3b8; }
  .slide-heading { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center; gap: 0.5rem; }
  .step-letter { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; background: #6366f1; color: #fff; border-radius: 50%; font-size: 1rem; font-weight: 800; flex-shrink: 0; }
