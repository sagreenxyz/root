---
import SlidesLayout from '../../../layouts/SlidesLayout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<SlidesLayout
  title="Nutrition &amp; Elimination – Slides – D439 Foundations of Nursing"
  protected={true}
  backHref={`${base}/private/d439/nutrition-elimination`}
  backLabel="← Full Article"
>
  <div class="slides-wrapper">

    <!-- COLUMN 1: Title -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-title">
          <div class="slide-badge">D439 – Foundations of Nursing</div>
          <div class="title-icon">🍽️</div>
          <h1 class="slide-main-title">Nutrition &amp; Elimination</h1>
          <h2 class="slide-subtitle">Tube Feedings · Catheters · Bowel Care · Aspiration</h2>
          <p class="slide-note">← → Arrow keys or Prev / Next buttons to navigate · ↓ Arrow key for optional detail slides</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 2: Constipation & Bowel Training -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">2 / 7</div>
          <h2 class="slide-heading">🚽 Constipation &amp; Bowel Training</h2>
          <p class="slide-intro">Prevention is key — especially with opioid medications. Anticipate and act proactively.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Prevention</h3>
              <ul class="bullet-list">
                <li>Fluids: <strong>2000–3000 mL/day</strong></li>
                <li>Fiber: <strong>25–35 g/day</strong></li>
                <li>Ambulation — promotes peristalsis</li>
                <li>Respond to urge promptly</li>
                <li>Upright positioning for defecation</li>
                <li><strong>Opioid-induced constipation</strong> — order bowel regimen PROACTIVELY with every opioid prescription</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Bowel Training Program</h3>
              <ul class="bullet-list">
                <li>Consistent time — <strong>20–40 min after breakfast</strong> (gastrocolic reflex strongest)</li>
                <li>High-fiber diet</li>
                <li>Abdominal massage: ascending → transverse → descending colon direction</li>
                <li>Digital stimulation / suppository if ordered</li>
                <li>Document pattern daily</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">Laxative Types</h3>
              <ul class="bullet-list">
                <li><strong>Docusate</strong> — stool softener</li>
                <li><strong>Psyllium</strong> — bulk-forming</li>
                <li><strong>MiraLax</strong> — osmotic</li>
                <li><strong>Bisacodyl</strong> — stimulant</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 3: Enteral Feeding -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">3 / 7</div>
          <h2 class="slide-heading">🍼 Enteral Tube Feedings</h2>
          <p class="slide-intro"><strong>ALWAYS verify tube placement BEFORE feeding</strong> — wrong placement → aspiration pneumonia or death.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Placement Verification</h3>
              <ul class="bullet-list">
                <li><strong>X-ray = gold standard</strong> (most accurate)</li>
                <li><strong>pH ≤5.5</strong> = gastric placement confirmed</li>
                <li>NEX measurement: nose → ear → xiphoid</li>
                <li>Insert with chin tucked to chest when swallowing</li>
                <li>Check GRV — hold if <strong>&gt;250–500 mL</strong> per policy</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Feeding Safety</h3>
              <ul class="bullet-list">
                <li>HOB <strong>30–45°</strong> during feeding AND 30–60 min after</li>
                <li>Flush with <strong>30 mL water</strong> before/after feeding and meds</li>
                <li>Room temperature formula</li>
                <li>Discard open formula after <strong>4–8 hours</strong></li>
                <li>NEVER use without confirmed placement</li>
                <li><strong>Routes:</strong> NG, nasoduodenal, NJ, PEG, J-tube</li>
              </ul>
            </div>
          </div>
          <div class="callout callout-tip">
            💡 Auscultation alone (air bolus) is NOT reliable for confirming tube placement — always use pH or X-ray.
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 4: Urinary Catheter Insertion -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">4 / 7</div>
          <h2 class="slide-heading">🩺 Urinary Catheter Insertion</h2>
          <p class="slide-intro"><strong>Sterile technique</strong> is required throughout. CAUTI is the most common healthcare-associated infection.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Female Insertion</h3>
              <ul class="bullet-list">
                <li>Position: dorsal recumbent</li>
                <li>Clean meatus: front-to-back, 3 separate swabs</li>
                <li>Non-dominant hand on labia = contaminated (do not move)</li>
                <li>Insert <strong>2–3 inches</strong> until urine flows</li>
                <li>Advance 1 more inch; inflate balloon (10 mL sterile water)</li>
                <li>Pull back gently to resistance; secure to inner thigh</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Male Insertion</h3>
              <ul class="bullet-list">
                <li>Position: supine; grasp penis at <strong>90°</strong></li>
                <li>Clean: circular motion outward, 3 swabs</li>
                <li>Insert <strong>7–9 inches</strong> until urine flows</li>
                <li>Advance 1 more inch; inflate balloon</li>
                <li>Replace foreskin if uncircumcised (prevents paraphimosis)</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">CAUTI Prevention</h3>
              <ul class="bullet-list">
                <li>Remove ASAP; daily perineal care</li>
                <li>Bag ALWAYS below bladder level</li>
                <li>Maintain closed drainage system</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 5: Removing Catheter & 24h Urine -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">5 / 7</div>
          <h2 class="slide-heading">🕐 Catheter Removal &amp; 24-Hour Urine</h2>
          <p class="slide-intro">Accurate 24-hour urine collection requires precise timing and complete collection. One missed void invalidates the collection.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Catheter Removal</h3>
              <ul class="bullet-list">
                <li>Aspirate ALL fluid from balloon (do NOT cut catheter)</li>
                <li>Withdraw gently and smoothly</li>
                <li>Monitor first void within <strong>4–6 hours</strong> (≥150 mL expected)</li>
                <li>Report if no void in <strong>6–8 hours</strong></li>
                <li>Watch for UTI symptoms: dysuria, frequency, urgency, hematuria</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">24-Hour Urine Collection</h3>
              <ul class="bullet-list">
                <li><strong>Discard FIRST void</strong> — note exact start time</li>
                <li>Collect ALL urine for next 24 hours</li>
                <li><strong>Last void at EXACTLY 24 hours IS collected</strong></li>
                <li>Label container with start and end times</li>
                <li>Refrigerate if required by lab</li>
                <li>If any urine is discarded → RESTART the collection</li>
                <li>Post sign in bathroom as reminder</li>
              </ul>
            </div>
          </div>
          <div class="callout">
            🔁 The FIRST void is discarded (establishes baseline); the LAST void IS included (completes 24 hours).
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 6: Aspiration Precautions & Diet -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide">
          <div class="slide-number">6 / 7</div>
          <h2 class="slide-heading">⚠️ Aspiration Precautions &amp; Clear Liquid Diet</h2>
          <p class="slide-intro">Aspiration of food or liquid causes aspiration pneumonia — a serious, preventable complication.</p>
          <div class="two-col">
            <div class="col-card">
              <h3 class="col-title">Aspiration Precautions</h3>
              <ul class="bullet-list">
                <li>HOB <strong>30–45°</strong> during and after meals/feedings</li>
                <li>Thicken liquids as ordered (nectar/honey/pudding thick)</li>
                <li>Small bites; allow adequate time</li>
                <li>Chin-tuck technique for dysphagic patients</li>
                <li>Suction equipment at bedside</li>
                <li>Speech-language pathology consult</li>
                <li>Oral care BEFORE meals (reduces bacterial load)</li>
              </ul>
            </div>
            <div class="col-card">
              <h3 class="col-title">Clear Liquid Diet</h3>
              <ul class="bullet-list">
                <li><strong>Allowed:</strong> water, ice chips, clear broth, plain gelatin (Jell-O), apple/white grape juice, popsicles, sports drinks, black coffee/plain tea, carbonated beverages</li>
              </ul>
              <h3 class="col-title" style="margin-top:0.75rem;">NOT Allowed on Clear Liquids</h3>
              <ul class="bullet-list">
                <li>Milk / dairy products</li>
                <li>Orange juice (opaque)</li>
                <li>Cream soups, pudding, ice cream</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 7: Exam Tips -->
    <div class="slide-column">
      <div class="column-inner">
        <div class="slide slide-exam">
          <div class="slide-number">7 / 7</div>
          <h2 class="slide-heading">📝 Exam Tips &amp; Key Points</h2>
          <div class="tips-grid">
            <div class="tip-card"><span class="tip-icon">✅</span><span class="tip-text">Always confirm tube placement BEFORE feeding — X-ray is gold standard</span></div>
            <div class="tip-card"><span class="tip-icon">🧪</span><span class="tip-text">pH ≤5.5 = gastric placement; GRV &gt;250–500 mL = hold feeding</span></div>
            <div class="tip-card"><span class="tip-icon">🛏️</span><span class="tip-text">HOB 30–45° during feedings AND 30–60 min after prevents aspiration</span></div>
            <div class="tip-card"><span class="tip-icon">👩</span><span class="tip-text">Female catheter insertion = 2–3 inches; Male = 7–9 inches</span></div>
            <div class="tip-card"><span class="tip-icon">🕐</span><span class="tip-text">24h urine: discard FIRST void; last void at 24h IS collected</span></div>
            <div class="tip-card"><span class="tip-icon">🦠</span><span class="tip-text">CAUTI = #1 healthcare-associated infection; remove catheter ASAP</span></div>
            <div class="tip-card"><span class="tip-icon">💊</span><span class="tip-text">Opioids = always anticipate constipation; order bowel regimen proactively</span></div>
            <div class="tip-card"><span class="tip-icon">🍏</span><span class="tip-text">Clear liquids: transparent at room temp; milk and OJ NOT allowed</span></div>
          </div>
          <div style="margin-top:1.5rem; text-align:center;">
            <a href={`${base}/private/d439/nutrition-elimination`} class="article-link">← Full Article</a>
            <a href={`${base}/private/d439`} class="article-link article-link-ghost">D439 Home</a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>
  .slide { padding: 4rem 3rem 2rem; }
  .slide.optional { padding-top: 5rem; }
  .opt-inner { max-width: 900px; width: 100%; margin: 0 auto; }
  .slide-number { position: absolute; top: 3.5rem; right: 1.5rem; font-size: 0.75rem; color: #94a3b8; font-weight: 600; }
  .slide-title { align-items: center; justify-content: center; text-align: center; background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%); }
  .slide-badge { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; color: #6366f1; background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 0.35rem; padding: 0.2rem 0.55rem; margin-bottom: 1rem; }
  .title-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .slide-main-title { font-size: 2.4rem; font-weight: 800; color: #1e293b; line-height: 1.15; margin-bottom: 0.25rem; }
  .slide-subtitle { font-size: 1.5rem; font-weight: 700; color: #6366f1; margin-bottom: 1.5rem; }
  .slide-note { font-size: 0.78rem; color: #94a3b8; }
  .slide-heading { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: 0.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center; gap: 0.5rem; }
  .step-letter { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; background: #6366f1; color: #fff; border-radius: 50%; font-size: 1rem; font-weight: 800; flex-shrink: 0; }
  .slide-intro { font-size: 0.95rem; color: #475569; line-height: 1.6; margin-bottom: 1rem; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; flex: 1; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; flex: 1; }
  .col-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.6rem; padding: 1rem; }
  .col-card-sm { padding: 0.85rem; }
  .col-title { font-size: 0.875rem; font-weight: 700; color: #6366f1; margin-bottom: 0.5rem; }
  .col-title-sm { font-size: 0.8rem; }
  .col-body { font-size: 0.82rem; color: #374151; margin-bottom: 0.4rem; }
  .col-example { font-size: 0.78rem; color: #64748b; font-style: italic; }
  .bullet-list { font-size: 0.85rem; color: #374151; line-height: 1.7; padding-left: 1.1rem; margin: 0; }
  .bullet-list li { margin-bottom: 0.25rem; }
  .callout { background: #eff6ff; border-left: 4px solid #bfdbfe; border-radius: 0.5rem; padding: 0.75rem 1rem; font-size: 0.85rem; color: #1e3a5f; line-height: 1.6; margin-top: auto; }
  .callout-tip { background: #eef2ff; border-left-color: #a5b4fc; color: #312e81; }
  .optional-hint { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: #94a3b8; margin-top: auto; padding-top: 0.5rem; }
  .back-hint { position: absolute; top: 3rem; left: 1.5rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: #94a3b8; }
  .optional-hint .arrow, .back-hint .arrow { font-size: 1rem; }
  .overview-grid { display: flex; flex-direction: column; gap: 0.5rem; flex: 1; margin-bottom: 0.75rem; }
  .overview-row { display: flex; align-items: flex-start; gap: 0.75rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 0.6rem 0.85rem; font-size: 0.875rem; color: #374151; }
  .step-badge { flex-shrink: 0; width: 1.75rem; height: 1.75rem; background: #6366f1; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.85rem; }
  .step-q { display: block; font-size: 0.78rem; color: #64748b; font-style: italic; margin-top: 0.1rem; }
  .slide-exam { background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 100%); }
  .tips-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; flex: 1; }
  .tip-card { display: flex; align-items: flex-start; gap: 0.6rem; background: #fff; border: 1px solid #e2e8f0; border-radius: 0.55rem; padding: 0.65rem 0.85rem; }
  .tip-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.05rem; }
  .tip-text { font-size: 0.84rem; color: #374151; line-height: 1.45; }
  .article-link { display: inline-flex; align-items: center; padding: 0.55rem 1.1rem; background: #6366f1; color: #fff; border-radius: 9999px; font-size: 0.875rem; font-weight: 600; text-decoration: none; margin: 0 0.25rem; }
  .article-link:hover { background: #4f46e5; }
  .article-link-ghost { background: #f1f5f9; color: #1e293b; border: 1px solid #e2e8f0; }
  .article-link-ghost:hover { background: #e2e8f0; }
  @media (max-width: 640px) {
    .slide { padding: 4rem 1.25rem 1.5rem; }
    .two-col, .three-col, .tips-grid { grid-template-columns: 1fr; }
    .slide-main-title { font-size: 1.8rem; }
    .slide-number { top: 3rem; right: 1rem; }
  }
  </style>
</SlidesLayout>
