---
import Layout from '../../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<Layout title="Private Dashboard – Root" protected={true}>
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
    <div>
      <h1 style="font-size:1.75rem; font-weight:800; margin-bottom:0.25rem;">📊 Private Dashboard</h1>
      <p style="color:#64748b; font-size:0.9rem;">Welcome back. Here's your private overview.</p>
    </div>
    <a
      href={`${base}/logout`}
      style="padding:0.5rem 1.25rem; background:#f1f5f9; color:#1e293b; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:0.875rem; font-weight:600; text-decoration:none; transition:background 0.2s;"
      onmouseover="this.style.background='#e2e8f0'"
      onmouseout="this.style.background='#f1f5f9'"
    >Sign Out</a>
  </div>

  <!-- Site stats -->
  <div style="display:grid; gap:1rem; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); margin-bottom:2rem;">
    {[
      { label: 'Pages', value: '6', icon: '📄' },
      { label: 'Users', value: '1', icon: '👤' },
      { label: 'Status', value: 'Live', icon: '🟢' },
      { label: 'Host', value: 'GitHub Pages', icon: '☁️' },
    ].map(card => (
      <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem;">
        <div style="font-size:1.5rem; margin-bottom:0.5rem;">{card.icon}</div>
        <div style="font-size:0.8rem; color:#64748b; text-transform:uppercase; letter-spacing:0.05em;">{card.label}</div>
        <div style="font-size:1.4rem; font-weight:700; margin-top:0.25rem;">{card.value}</div>
      </div>
    ))}
  </div>

  <!-- About private content -->
  <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.5rem; margin-bottom:1rem;">
    <h2 style="font-size:1rem; font-weight:600; margin-bottom:0.75rem;">🔒 About Private Content</h2>
    <p style="color:#64748b; font-size:0.9rem; line-height:1.6; margin-bottom:0.75rem;">
      This private area contains content that is encrypted at build time using AES-256-GCM. Your credentials
      are used to derive a decryption key locally in your browser — nothing is sent to a server.
    </p>
    <p style="color:#64748b; font-size:0.9rem; line-height:1.6;">
      Each encrypted file is stored as opaque ciphertext in the repository. Only someone with the correct
      credentials can decrypt and read the content.
    </p>
  </div>

  <!-- Quick links to private sections -->
  <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.5rem; margin-bottom:1rem;">
    <h2 style="font-size:1rem; font-weight:600; margin-bottom:0.75rem;">Quick Links</h2>
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
      <a href={`${base}/content`} style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.5rem 1rem; background:#eef2ff; color:#4f46e5; border:1px solid #c7d2fe; border-radius:0.5rem; text-decoration:none; font-size:0.875rem; font-weight:600; transition:background 0.15s;"
        onmouseover="this.style.background='#e0e7ff'"
        onmouseout="this.style.background='#eef2ff'"
      >🔒 Encrypted Content Vault</a>
      <a href={`${base}/public`} style="display:inline-flex; align-items:center; gap:0.4rem; padding:0.5rem 1rem; background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; border-radius:0.5rem; text-decoration:none; font-size:0.875rem; font-weight:600; transition:background 0.15s;"
        onmouseover="this.style.background='#dcfce7'"
        onmouseout="this.style.background='#f0fdf4'"
      >🌐 Public Content</a>
    </div>
  </div>

  <!-- Session info -->
  <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.5rem;">
    <h2 style="font-size:1rem; font-weight:600; margin-bottom:1rem;">Session Info</h2>
    <p id="session-user" style="color:#64748b; font-size:0.9rem;"></p>
  </div>
</Layout>

<script>
  const user = sessionStorage.getItem('auth_user') || 'unknown';
  const sessionUserEl = document.getElementById('session-user');
  if (sessionUserEl) sessionUserEl.textContent = `Logged in as: ${user}`;
</script>
