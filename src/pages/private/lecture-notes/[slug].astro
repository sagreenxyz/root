---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');

export async function getStaticPaths() {
  const notes = await getCollection('lecture-notes');
  return notes.map(note => ({
    params: { slug: note.id.replace(/\.md$/, '') },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

// Prev / next navigation (sorted newest-first)
const allNotes = await getCollection('lecture-notes');
const sorted = allNotes.sort((a, b) => b.data.date.localeCompare(a.data.date));
const currentSlug = note.id.replace(/\.md$/, '');
const currentIndex = sorted.findIndex(n => n.id.replace(/\.md$/, '') === currentSlug);
const prevNote = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextNote = currentIndex > 0 ? sorted[currentIndex - 1] : null;
---

<Layout title={`${note.data.title} – Lecture Notes`} protected={true}>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" style="margin-bottom:1.5rem; font-size:0.85rem; color:#64748b;">
    <a href={`${base}/private/dashboard`} style="color:#6366f1; text-decoration:none; font-weight:500;">Dashboard</a>
    <span style="margin:0 0.4rem;">›</span>
    <a href={`${base}/private/lecture-notes`} style="color:#6366f1; text-decoration:none; font-weight:500;">Lecture Notes</a>
    <span style="margin:0 0.4rem;">›</span>
    <span style="color:#94a3b8;">{note.data.title}</span>
  </nav>

  <div class="note-grid">

    <!-- Main content -->
    <article>
      <!-- Header card -->
      <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.5rem; margin-bottom:1.5rem;">
        <div style="display:flex; align-items:flex-start; gap:0.75rem; margin-bottom:1rem;">
          <span style="font-size:2rem; line-height:1; flex-shrink:0;">📝</span>
          <div>
            <h1 style="font-size:1.5rem; font-weight:800; color:#1e293b; line-height:1.3; margin-bottom:0.5rem;">
              {note.data.title}
            </h1>
            <div style="display:flex; flex-wrap:wrap; gap:0.5rem; align-items:center; font-size:0.8rem; color:#64748b;">
              <span style="background:#eef2ff; color:#4f46e5; border:1px solid #c7d2fe; border-radius:0.4rem; padding:0.15rem 0.5rem; font-weight:600;">
                {note.data.course}
              </span>
              <span>{note.data.date}</span>
              {note.data.lecturer && <span>· {note.data.lecturer}</span>}
              {note.data.issueNumber && (
                <a
                  href={`https://github.com/sagreenxyz/sagreenxyz.github.io/issues/${note.data.issueNumber}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  style="color:#6366f1; text-decoration:none; background:#eef2ff; border:1px solid #c7d2fe; border-radius:0.3rem; padding:0.1rem 0.45rem;"
                >
                  Issue #{note.data.issueNumber}
                </a>
              )}
            </div>
          </div>
        </div>

        {note.data.summary && (
          <p style="color:#475569; font-size:0.925rem; line-height:1.7; padding-top:1rem; border-top:1px solid #f1f5f9;">
            {note.data.summary}
          </p>
        )}
      </div>

      <!-- Note body -->
      <div class="note-content">
        <Content />
      </div>

      <!-- Prev / Next navigation -->
      <div style="display:flex; gap:1rem; margin-top:2rem; flex-wrap:wrap;">
        {prevNote && (
          <a
            href={`${base}/private/lecture-notes/${prevNote.id.replace(/\.md$/, '')}`}
            style="flex:1; min-width:200px; background:#fff; border:1px solid #e2e8f0; border-radius:0.65rem; padding:1rem 1.25rem; text-decoration:none; color:inherit; display:flex; flex-direction:column; gap:0.25rem; transition:border-color 0.2s;"
            onmouseover="this.style.borderColor='#a5b4fc';"
            onmouseout="this.style.borderColor='#e2e8f0';"
          >
            <span style="font-size:0.7rem; color:#94a3b8; text-transform:uppercase; letter-spacing:0.06em;">← Older</span>
            <span style="font-size:0.875rem; font-weight:600; color:#1e293b;">{prevNote.data.title}</span>
          </a>
        )}
        {nextNote && (
          <a
            href={`${base}/private/lecture-notes/${nextNote.id.replace(/\.md$/, '')}`}
            style="flex:1; min-width:200px; background:#fff; border:1px solid #e2e8f0; border-radius:0.65rem; padding:1rem 1.25rem; text-decoration:none; color:inherit; display:flex; flex-direction:column; gap:0.25rem; text-align:right; transition:border-color 0.2s;"
            onmouseover="this.style.borderColor='#a5b4fc';"
            onmouseout="this.style.borderColor='#e2e8f0';"
          >
            <span style="font-size:0.7rem; color:#94a3b8; text-transform:uppercase; letter-spacing:0.06em;">Newer →</span>
            <span style="font-size:0.875rem; font-weight:600; color:#1e293b;">{nextNote.data.title}</span>
          </a>
        )}
      </div>
    </article>

    <!-- Sidebar -->
    <aside>
      <!-- Tags -->
      {note.data.tags.length > 0 && (
        <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem; margin-bottom:1rem;">
          <p style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#64748b; margin-bottom:0.75rem;">Tags</p>
          <div style="display:flex; flex-wrap:wrap; gap:0.4rem;">
            {note.data.tags.map(tag => (
              <span style="font-size:0.75rem; color:#475569; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:0.3rem; padding:0.15rem 0.5rem;">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Back link -->
      <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem;">
        <a
          href={`${base}/private/lecture-notes`}
          style="display:flex; align-items:center; gap:0.5rem; color:#6366f1; text-decoration:none; font-size:0.875rem; font-weight:600;"
        >
          ← All Lecture Notes
        </a>
      </div>
    </aside>

  </div>
</Layout>

<style>
  .note-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 1.5rem;
    align-items: start;
  }

  .note-content {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    padding: 2rem;
    line-height: 1.8;
    color: #1e293b;
  }

  .note-content h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 1.75rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #f1f5f9;
    color: #1e293b;
  }

  .note-content h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 1.25rem 0 0.5rem;
    color: #334155;
  }

  .note-content p {
    margin-bottom: 1rem;
    color: #374151;
  }

  .note-content ul,
  .note-content ol {
    margin: 0.5rem 0 1rem 1.5rem;
    color: #374151;
  }

  .note-content li {
    margin-bottom: 0.35rem;
  }

  .note-content strong {
    color: #1e293b;
    font-weight: 700;
  }

  .note-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
  }

  .note-content th {
    background: #f8fafc;
    font-weight: 700;
    padding: 0.6rem 0.75rem;
    border: 1px solid #e2e8f0;
    text-align: left;
  }

  .note-content td {
    padding: 0.6rem 0.75rem;
    border: 1px solid #e2e8f0;
    vertical-align: top;
  }

  .note-content tr:nth-child(even) td {
    background: #f8fafc;
  }

  .note-content a {
    color: #6366f1;
    text-decoration: underline;
  }

  .note-content blockquote {
    border-left: 3px solid #c7d2fe;
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    background: #eef2ff;
    color: #3730a3;
    border-radius: 0 0.4rem 0.4rem 0;
  }

  .note-content hr {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 1.5rem 0;
  }

  @media (max-width: 768px) {
    .note-grid {
      grid-template-columns: 1fr;
    }

    .note-grid > aside {
      order: -1;
    }
  }
</style>
