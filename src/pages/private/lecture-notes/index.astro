---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');

const allNotes = await getCollection('lecture-notes');
const notes = allNotes.sort((a, b) => {
  // Sort newest first by date field
  return b.data.date.localeCompare(a.data.date);
});

// Group by course
const courseMap: Record<string, typeof notes> = {};
for (const note of notes) {
  const course = note.data.course;
  if (!courseMap[course]) courseMap[course] = [];
  courseMap[course].push(note);
}
---

<Layout title="Lecture Notes – Root" protected={true}>

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" style="margin-bottom:1.5rem; font-size:0.85rem; color:#64748b;">
    <a href={`${base}/private/dashboard`} style="color:#6366f1; text-decoration:none; font-weight:500;">Dashboard</a>
    <span style="margin:0 0.4rem;">›</span>
    <span>Lecture Notes</span>
  </nav>

  <!-- Header -->
  <div style="margin-bottom:2rem;">
    <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
      <span style="font-size:2rem;">📖</span>
      <h1 style="font-size:2rem; font-weight:800;">Lecture Notes</h1>
    </div>
    <p style="color:#64748b; font-size:1rem; line-height:1.6; max-width:720px;">
      Private course lecture notes captured from class sessions, refined by the Copilot
      agent, and stored here for review. Each note links back to its originating GitHub
      Issue for full traceability.
    </p>
  </div>

  <!-- Workflow callout -->
  <div style="background:#eef2ff; border:1px solid #c7d2fe; border-radius:0.75rem; padding:1.25rem 1.5rem; margin-bottom:2rem; display:flex; align-items:flex-start; gap:0.75rem;">
    <span style="font-size:1.25rem; flex-shrink:0;">💡</span>
    <div>
      <p style="font-weight:700; font-size:0.9rem; color:#3730a3; margin-bottom:0.25rem;">Note Capture Workflow</p>
      <p style="color:#4338ca; font-size:0.85rem; line-height:1.6;">
        Open a <strong>Lecture Note</strong> GitHub Issue with your raw notes → the Copilot agent
        refines them → a polished markdown file is added here on the private side.
        Raw intake issues are closed automatically when the note is published.
      </p>
    </div>
  </div>

  {notes.length === 0 ? (
    <!-- Empty state -->
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:3rem; text-align:center; color:#64748b;">
      <div style="font-size:2.5rem; margin-bottom:1rem;">📭</div>
      <p style="font-weight:600; margin-bottom:0.5rem;">No lecture notes yet</p>
      <p style="font-size:0.875rem;">
        Create a <strong>Lecture Note</strong> GitHub Issue to capture your first set of notes.
      </p>
    </div>
  ) : (
    <div style="display:flex; flex-direction:column; gap:2.5rem;">
      {Object.entries(courseMap).map(([course, courseNotes]) => (
        <section>
          <!-- Course header -->
          <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:1rem; padding-bottom:0.5rem; border-bottom:2px solid #e2e8f0;">
            <span style="font-size:1rem; font-weight:700; color:#1e293b;">{course}</span>
            <span style="font-size:0.75rem; color:#6366f1; background:#eef2ff; border:1px solid #c7d2fe; border-radius:1rem; padding:0.1rem 0.6rem;">
              {courseNotes.length} {courseNotes.length === 1 ? 'note' : 'notes'}
            </span>
          </div>

          <!-- Note cards -->
          <div style="display:flex; flex-direction:column; gap:1rem;">
            {courseNotes.map((note) => (
              <a
                href={`${base}/private/lecture-notes/${note.id.replace(/\.md$/, '')}`}
                style="display:block; background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.25rem 1.5rem; text-decoration:none; color:inherit; transition:box-shadow 0.2s, border-color 0.2s;"
                onmouseover="this.style.boxShadow='0 4px 16px rgba(99,102,241,0.12)'; this.style.borderColor='#a5b4fc';"
                onmouseout="this.style.boxShadow='none'; this.style.borderColor='#e2e8f0';"
              >
                <div style="display:flex; align-items:flex-start; gap:1rem;">
                  <div style="font-size:1.75rem; line-height:1; flex-shrink:0;">📝</div>
                  <div style="flex:1; min-width:0;">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.35rem; flex-wrap:wrap;">
                      <span style="font-size:0.72rem; color:#94a3b8;">{note.data.date}</span>
                      {note.data.lecturer && (
                        <span style="font-size:0.72rem; color:#64748b;">· {note.data.lecturer}</span>
                      )}
                      {note.data.issueNumber && (
                        <span style="font-size:0.72rem; color:#6366f1; background:#eef2ff; border:1px solid #c7d2fe; border-radius:0.3rem; padding:0.1rem 0.4rem;">
                          #{note.data.issueNumber}
                        </span>
                      )}
                    </div>
                    <h2 style="font-size:1.05rem; font-weight:700; color:#1e293b; margin-bottom:0.35rem;">{note.data.title}</h2>
                    {note.data.summary && (
                      <p style="color:#64748b; font-size:0.875rem; line-height:1.6; margin-bottom:0.6rem;">{note.data.summary}</p>
                    )}
                    {note.data.tags.length > 0 && (
                      <div style="display:flex; gap:0.35rem; flex-wrap:wrap;">
                        {note.data.tags.map(tag => (
                          <span style="font-size:0.72rem; color:#475569; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:0.3rem; padding:0.1rem 0.45rem;">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div style="color:#94a3b8; font-size:1.2rem; flex-shrink:0; align-self:center;">›</div>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</Layout>
