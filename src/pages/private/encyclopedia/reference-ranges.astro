          <div>
            <p style="font-weight:700; color:#1e293b; font-size:0.9rem; margin-bottom:0.25rem;">{title}</p>
            <p style="font-size:0.85rem; color:#334155; line-height:1.6;">{detail}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

