          </tr>
        </thead>
        <tbody>
          {[
            { fluid: '0.9% NaCl (Normal saline)', na: '154', tonicity: 'Isotonic', indications: 'Volume resuscitation, hypovolaemia, hypochloraemic alkalosis' },
            { fluid: 'Lactated Ringer\'s (LR)', na: '130', tonicity: 'Isotonic', indications: 'Volume resuscitation, burns, trauma (preferred balanced crystalloid)' },
            { fluid: 'Plasmalyte 148', na: '140', tonicity: 'Isotonic', indications: 'Balanced crystalloid; large-volume resuscitation' },
            { fluid: '0.45% NaCl (Half-normal)', na: '77', tonicity: 'Hypotonic', indications: 'Free water replacement (hypernatraemia); maintenance (not resuscitation)' },
            { fluid: '5% Dextrose in water (D5W)', na: '0', tonicity: 'Hypotonic (metabolised)', indications: 'Free water supplementation, drug diluent; not for volume resuscitation' },
            { fluid: '3% NaCl (Hypertonic saline)', na: '513', tonicity: 'Hypertonic', indications: 'Severe symptomatic hyponatraemia, cerebral oedema, TBI osmotherapy' },
            { fluid: '5% Albumin', na: '~145', tonicity: 'Oncotically active', indications: 'Hypoalbuminaemia, cirrhosis (SBP, large-volume paracentesis), septic shock (selected)' },
