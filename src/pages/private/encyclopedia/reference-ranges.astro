  <!-- ABG Interpretation Steps -->
  <section id="abg-steps" style="margin-bottom:2.5rem;">
    <h2 style="font-size:1.25rem; font-weight:700; color:#1e293b; margin-bottom:1rem; padding-bottom:0.4rem; border-bottom:2px solid #e2e8f0; display:flex; align-items:center; gap:0.5rem;">
      📋 Systematic ABG Interpretation — Step by Step
    </h2>
    <div style="display:flex; flex-direction:column; gap:0.75rem;">
      {[
        { step: 1, title: 'Assess pH', detail: 'pH < 7.35 = acidaemia | pH 7.35–7.45 = normal (may be mixed) | pH > 7.45 = alkalaemia', color: '#fee2e2', border: '#fca5a5', num: '#dc2626' },
        { step: 2, title: 'Identify primary disorder', detail: 'PaCO₂ moves same direction as pH? → respiratory disorder. HCO₃⁻ moves same direction as pH? → metabolic disorder.', color: '#fef3c7', border: '#fcd34d', num: '#d97706' },
        { step: 3, title: 'Assess compensation', detail: 'Use compensation formulae. If measured value ≠ expected → mixed disorder present.', color: '#d1fae5', border: '#6ee7b7', num: '#059669' },
        { step: 4, title: 'Calculate anion gap (if metabolic acidosis)', detail: 'AG = Na⁺ − (Cl⁻ + HCO₃⁻). Normal 8–12. If high AG: check delta-delta ratio = ΔAG / ΔHCO₃⁻. Ratio < 1 → concurrent normal-AG acidosis; ratio > 2 → concurrent metabolic alkalosis.', color: '#e0f2fe', border: '#7dd3fc', num: '#0369a1' },
        { step: 5, title: 'Assess oxygenation', detail: 'PaO₂ (normal 80–100 mmHg). SpO₂ (normal ≥ 95%). Calculate A-a gradient if appropriate. Elevated A-a gradient → V/Q mismatch, shunt, or diffusion defect.', color: '#ede9fe', border: '#c4b5fd', num: '#7c3aed' },
        { step: 6, title: 'Correlate with clinical context', detail: 'Always interpret the ABG in the context of the patient\'s history, presenting illness, medications, and clinical examination. No laboratory result should be interpreted in isolation.', color: '#f0fdf4', border: '#86efac', num: '#16a34a' },
      ].map(({ step, title, detail, color, border, num }) => (
        <div style={`background:${color}; border:1px solid ${border}; border-radius:0.65rem; padding:1rem 1.25rem; display:flex; gap:1rem; align-items:flex-start;`}>
