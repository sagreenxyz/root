        <dl style="font-size:0.85rem; display:grid; gap:0.6rem;">
          {[
            { term: 'Founders', def: 'William R. Miller &amp; Stephen Rollnick (1983–1991)' },
            { term: 'MI Spirit (PACE)', def: 'Partnership, Acceptance, Compassion, Evocation' },
            { term: 'Four Processes', def: 'Engaging → Focusing → Evoking → Planning' },
            { term: 'Core Skills', def: 'OARS: Open questions, Affirmations, Reflections, Summaries' },
            { term: 'Change Talk', def: 'DARN-CAT: Desire, Ability, Reason, Need; Commitment, Activation, Taking Steps' },
