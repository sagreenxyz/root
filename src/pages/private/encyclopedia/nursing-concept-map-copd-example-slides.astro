<script>
  /**
   * Process Indicator — shows where in the 7-phase concept map process
   * each slide sits. A compact panel is fixed to the left edge of the
   * viewport; the active phase dot is highlighted in orange.
   *
   * The indicator is appended directly to document.body so it is never
   * clipped by #slides-outer (which has overflow:hidden).
   */
  (function () {
    const PHASES = [
      'Data Collection',
      'Data Organisation',
      'Clinical Reasoning',
      'Goal Setting',
      'Intervention Planning',
      'Drawing Connections',
      'Evaluation',
    ];

    // Maps slide column index (0-based) to the active phase number.
    // 0  = no phase highlighted (intro/overview slides)
    // 1–7 = that specific phase highlighted
    // -1 = all phases highlighted (takeaways / all-phases-complete)
    const colPhaseMap: Record<number, number> = {
      0: 0,   // Col 0 · Title slide
      1: 0,   // Col 1 · Case Overview (pre-process)
      2: 1,   // Col 2 · Phase 1: Data Collection
      3: 2,   // Col 3 · Phase 2: Data Organisation
      4: 3,   // Col 4 · Phase 3: Clinical Reasoning
      5: 4,   // Col 5 · Phase 4: Goal Setting
      6: 5,   // Col 6 · Phase 5: Intervention Planning
      7: 6,   // Col 7 · Phase 6: Drawing Connections
      8: 7,   // Col 8 · Phase 7: Evaluation
      9: -1,  // Col 9 · Key Takeaways (all phases complete)
    };

    // ── Build the indicator panel ─────────────────────────────────────────
    const panel = document.createElement('div');
    panel.id = 'concept-process-indicator';
    panel.setAttribute('aria-label', 'Concept map process steps indicator');
    panel.setAttribute('role', 'complementary');
    Object.assign(panel.style, {
      position: 'fixed',
      left: '0',
      top: '50%',
      transform: 'translateY(-50%)',
      zIndex: '50',
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'flex-start',
      gap: '0',
      background: 'rgba(15, 23, 42, 0.88)',
      WebkitBackdropFilter: 'blur(6px)',
      backdropFilter: 'blur(6px)',
      borderRadius: '0 0.75rem 0.75rem 0',
      padding: '0.65rem 0.85rem 0.65rem 0.5rem',
      userSelect: 'none',
      fontFamily: 'system-ui, -apple-system, sans-serif',
    });

    // "CONCEPT MAP PROCESS" heading at the top of the panel
    const heading = document.createElement('div');
    heading.textContent = 'Concept Map Process';
    Object.assign(heading.style, {
      fontSize: '0.55rem',
      fontWeight: '700',
      letterSpacing: '0.08em',
      textTransform: 'uppercase',
      color: 'rgba(255,255,255,0.4)',
      marginBottom: '0.5rem',
      width: '100%',
      textAlign: 'center',
    });
    panel.appendChild(heading);

    // ── Phase dot items ──────────────────────────────────────────────────
    const DOT_SIZE    = 22;  // px — circle diameter
    const LINE_WIDTH  = 2;   // px — connector line width
    const LINE_OFFSET = (DOT_SIZE - LINE_WIDTH) / 2;  // centres line under dot column

    const items: Array<{ dot: HTMLElement; numEl: HTMLElement; labelEl: HTMLElement }> = [];

    PHASES.forEach((name, i) => {
      const phaseNum = i + 1;

      // Connector line between items — aligned with the centre of the dot column
      if (i > 0) {
        const line = document.createElement('div');
        Object.assign(line.style, {
          width: `${LINE_WIDTH}px`,
          height: '8px',
          background: 'rgba(255,255,255,0.18)',
          marginLeft: `${LINE_OFFSET}px`,
          borderRadius: '1px',
        });
        panel.appendChild(line);
      }

      // Row wrapper: [dot] [label text]
      const item = document.createElement('div');
      Object.assign(item.style, {
        display: 'flex',
        flexDirection: 'row',
        alignItems: 'center',
        gap: '0.45rem',
        cursor: 'default',
        transition: 'opacity 0.3s',
      });

      // Circle dot with phase number
      const dot = document.createElement('div');
      Object.assign(dot.style, {
        width: `${DOT_SIZE}px`,
        height: `${DOT_SIZE}px`,
        flexShrink: '0',
        borderRadius: '50%',
        background: 'rgba(255,255,255,0.12)',
        border: '1.5px solid rgba(255,255,255,0.18)',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        transition: 'background 0.3s, border-color 0.3s, transform 0.3s',
        boxSizing: 'border-box',
      });

      const numEl = document.createElement('span');
      numEl.textContent = String(phaseNum);
      Object.assign(numEl.style, {
        fontSize: '0.6rem',
        fontWeight: '800',
        color: 'rgba(255,255,255,0.35)',
        lineHeight: '1',
        transition: 'color 0.3s',
      });
      dot.appendChild(numEl);

      // Visible phase name label
      const labelEl = document.createElement('span');
      labelEl.textContent = name;
      Object.assign(labelEl.style, {
        fontSize: '0.65rem',
        fontWeight: '600',
        color: 'rgba(255,255,255,0.25)',
        lineHeight: '1.2',
        transition: 'color 0.3s, font-weight 0.3s',
        whiteSpace: 'nowrap',
      });

      item.appendChild(dot);
      item.appendChild(labelEl);
      panel.appendChild(item);
      items.push({ dot, numEl, labelEl });
    });

    document.body.appendChild(panel);

    // ── Update dots to reflect the current slide column ───────────────────
    function updateIndicator() {
      const wrapper = document.querySelector<HTMLElement>('.slides-wrapper');
      if (!wrapper) return;

      const match = wrapper.style.transform.match(/translateX\((-?\d+(?:\.\d+)?)px\)/);
      const tx = match ? parseFloat(match[1]) : 0;
      const col = Math.round(Math.abs(tx) / window.innerWidth);
      const activePhase = colPhaseMap[col] ?? 0;

      items.forEach(({ dot, numEl, labelEl }, i) => {
        const phase = i + 1;

        if (activePhase === -1) {
          // All-complete state (Key Takeaways slide)
          dot.style.background = 'rgba(234,88,12,0.55)';
          dot.style.borderColor = 'rgba(234,88,12,0.75)';
          dot.style.transform = 'scale(1)';
          numEl.style.color = '#fff';
          labelEl.style.color = 'rgba(255,255,255,0.75)';
          labelEl.style.fontWeight = '600';
          (dot.parentElement as HTMLElement).style.opacity = '1';
        } else if (activePhase === 0) {
          // No active phase (Title / Case Overview)
          dot.style.background = 'rgba(255,255,255,0.10)';
          dot.style.borderColor = 'rgba(255,255,255,0.15)';
          dot.style.transform = 'scale(1)';
          numEl.style.color = 'rgba(255,255,255,0.3)';
          labelEl.style.color = 'rgba(255,255,255,0.25)';
          labelEl.style.fontWeight = '600';
          (dot.parentElement as HTMLElement).style.opacity = '0.65';
        } else if (phase === activePhase) {
          // Currently active phase
          dot.style.background = '#ea580c';
          dot.style.borderColor = '#ea580c';
          dot.style.transform = 'scale(1.2)';
          numEl.style.color = '#fff';
          labelEl.style.color = '#fff';
          labelEl.style.fontWeight = '700';
          (dot.parentElement as HTMLElement).style.opacity = '1';
        } else if (phase < activePhase) {
          // Already-covered phase
          dot.style.background = 'rgba(234,88,12,0.28)';
          dot.style.borderColor = 'rgba(234,88,12,0.45)';
          dot.style.transform = 'scale(1)';
          numEl.style.color = 'rgba(255,255,255,0.65)';
          labelEl.style.color = 'rgba(255,255,255,0.55)';
          labelEl.style.fontWeight = '600';
          (dot.parentElement as HTMLElement).style.opacity = '0.9';
        } else {
          // Upcoming phase
          dot.style.background = 'rgba(255,255,255,0.08)';
          dot.style.borderColor = 'rgba(255,255,255,0.13)';
          dot.style.transform = 'scale(1)';
          numEl.style.color = 'rgba(255,255,255,0.22)';
          labelEl.style.color = 'rgba(255,255,255,0.18)';
          labelEl.style.fontWeight = '600';
          (dot.parentElement as HTMLElement).style.opacity = '0.5';
        }
      });
    }

    // ── Watch .slides-wrapper's transform for navigation changes ─────────
    function watchWrapper() {
      const wrapper = document.querySelector('.slides-wrapper');
      if (!wrapper) return;
      const observer = new MutationObserver(updateIndicator);
      // MutationObserver is intentionally not disconnected: this is a full-page
      // presentation; the wrapper persists for the entire page lifetime.
      observer.observe(wrapper, { attributes: true, attributeFilter: ['style'] });
      // Debounced resize handler — recalculates the active phase after the user
      // finishes resizing the window (SlidesLayout uses window.innerWidth in its
      // translateX transform, so column boundaries shift on resize).
      let resizeTimer: ReturnType<typeof setTimeout> | undefined;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(updateIndicator, 100);
      }, { passive: true });
      updateIndicator();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', watchWrapper);
    } else {
      watchWrapper();
    }
  })();
</script>
