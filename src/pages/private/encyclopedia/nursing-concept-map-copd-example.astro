                ['Ineffective Airway Clearance', 'worsens →', 'Impaired Gas Exchange'],
                ['Impaired Gas Exchange', 'causes/worsens →', 'Anxiety (Dx 4)'],
                ['Impaired Gas Exchange', 'contributes to →', 'Activity Intolerance (Dx 3)'],
