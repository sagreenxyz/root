---
import Layout from '../layouts/Layout.astro';

if (!import.meta.env.PUBLIC_AUTH_USERNAME || !import.meta.env.PUBLIC_AUTH_PASSWORD_HASH) {
  console.warn(
    '[login] PUBLIC_AUTH_USERNAME or PUBLIC_AUTH_PASSWORD_HASH is not configured. ' +
    'Set AUTH_USERNAME and AUTH_PASSWORD_HASH as GitHub Repository secrets, ' +
    'or add them to .env.local for local development.'
  );
}
---

<Layout title="Login – Root" protected={false}>
  <div style="max-width: 400px; margin: 4rem auto; background: #fff; border: 1px solid #e2e8f0; border-radius: 1rem; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,.06);">
    <div style="text-align:center; margin-bottom:2rem;">
      <div style="font-size:2.5rem; margin-bottom:0.5rem;">🔐</div>
      <h1 style="font-size:1.5rem; font-weight:700;">Sign In</h1>
      <p style="color:#64748b; font-size:0.9rem; margin-top:0.25rem;">Enter your credentials to continue</p>
    </div>

    <form id="login-form" autocomplete="on">
      <div style="margin-bottom:1rem;">
        <label for="username" style="display:block; font-size:0.875rem; font-weight:500; margin-bottom:0.4rem;">Username</label>
        <input
          id="username"
          name="username"
          type="text"
          autocomplete="username"
          placeholder="username"
          required
          style="width:100%; padding:0.6rem 0.8rem; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:1rem; outline:none; transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#6366f1'"
          onblur="this.style.borderColor='#e2e8f0'"
        />
      </div>
      <div style="margin-bottom:1.5rem;">
        <label for="password" style="display:block; font-size:0.875rem; font-weight:500; margin-bottom:0.4rem;">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          placeholder="••••••••"
          required
          style="width:100%; padding:0.6rem 0.8rem; border:1px solid #e2e8f0; border-radius:0.5rem; font-size:1rem; outline:none; transition:border-color 0.2s;"
          onfocus="this.style.borderColor='#6366f1'"
          onblur="this.style.borderColor='#e2e8f0'"
        />
      </div>
      <div id="error-msg" style="display:none; color:#dc2626; font-size:0.875rem; margin-bottom:1rem; padding:0.5rem 0.75rem; background:#fef2f2; border-radius:0.4rem; border:1px solid #fecaca;"></div>
      <button
        type="submit"
        style="width:100%; padding:0.75rem; background:#6366f1; color:#fff; border:none; border-radius:0.5rem; font-size:1rem; font-weight:600; cursor:pointer; transition:background 0.2s;"
        onmouseover="this.style.background='#4f46e5'"
        onmouseout="this.style.background='#6366f1'"
      >Sign In</button>
    </form>
    <p style="text-align:center; margin-top:1.5rem; color:#64748b; font-size:0.8rem;">Contact the site administrator if you need access.</p>
  </div>
</Layout>

<script>
  // Credentials are configured via GitHub Repository secrets (AUTH_USERNAME and
  // AUTH_PASSWORD_HASH) and injected at build time as PUBLIC_ environment variables.
  // AUTH_PASSWORD_HASH must be the SHA-256 hex digest of the raw password.
  const VALID_USERNAME = import.meta.env.PUBLIC_AUTH_USERNAME as string;
  const VALID_PASSWORD_HASH = import.meta.env.PUBLIC_AUTH_PASSWORD_HASH as string;

  /**
   * Returns the SHA-256 hex digest of the given message using the Web Crypto API.
   */
  async function sha256(message: string): Promise<string> {
    const msgBuffer = new TextEncoder().encode(message);
    const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  }

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLElement;

  if (!VALID_USERNAME || !VALID_PASSWORD_HASH) {
    errorMsg.textContent = 'Authentication is not configured. Contact the site administrator.';
    errorMsg.style.display = 'block';
    const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    // Trim leading/trailing whitespace from the username; passwords are intentionally NOT trimmed.
    const username = (document.getElementById('username') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const passwordHash = await sha256(password);

    if (username === VALID_USERNAME && passwordHash === VALID_PASSWORD_HASH) {
      // Store a session token — no plaintext credentials are kept
      const sessionToken = await sha256(`${username}:${password}`);
      sessionStorage.setItem('auth_token', sessionToken);
      sessionStorage.setItem('auth_user', username);

      // Redirect to 'next' param or home
      const params = new URLSearchParams(window.location.search);
      const next = params.get('next') || (import.meta.env.BASE_URL || '/');
      window.location.replace(next);
    } else {
      errorMsg.textContent = 'Invalid username or password. Please try again.';
      errorMsg.style.display = 'block';
      (document.getElementById('password') as HTMLInputElement).value = '';
    }
  });

  // Redirect if already authenticated
  if (sessionStorage.getItem('auth_token')) {
    window.location.replace(import.meta.env.BASE_URL || '/');
  }
</script>
