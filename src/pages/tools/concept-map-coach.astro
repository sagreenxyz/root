---
import Layout from '../../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<Layout title="Concept Map Coach – WGU Nursing Tools" protected={false}>

<style>
  /* ── Page shell ─────────────────────────────────────────────────── */
  .cmc-page { max-width: 860px; margin: 0 auto; }
  .cmc-page h1 { font-size: 1.75rem; font-weight: 800; color: #1e293b; margin-bottom: 0.3rem; }
  .cmc-page .subtitle { color: #64748b; font-size: 0.95rem; margin-bottom: 1.5rem; line-height: 1.55; }

  /* ── Phase progress bar ─────────────────────────────────────────── */
  .phase-bar {
    display: flex;
    gap: 0;
    margin-bottom: 1.75rem;
    border-radius: 0.6rem;
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }
  .phase-pip {
    flex: 1;
    padding: 0.55rem 0.25rem;
    text-align: center;
    font-size: 0.7rem;
    font-weight: 700;
    background: #f8fafc;
    color: #94a3b8;
    border-right: 1px solid #e2e8f0;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    line-height: 1.3;
    user-select: none;
  }
  .phase-pip:last-child { border-right: none; }
  .phase-pip.active { background: #6366f1; color: #fff; }
  .phase-pip.done   { background: #dcfce7; color: #15803d; }
  .phase-pip:hover:not(.active) { background: #eef2ff; color: #4f46e5; }

  /* ── Step indicator ─────────────────────────────────────────────── */
  .step-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .step-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: #e2e8f0;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }
  .step-dot.active  { background: #6366f1; transform: scale(1.35); }
  .step-dot.done    { background: #22c55e; }
  .step-label {
    font-size: 0.78rem;
    color: #94a3b8;
    margin-left: 0.5rem;
  }

  /* ── Coach card ─────────────────────────────────────────────────── */
  .coach-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .coach-header {
    background: #1e293b;
    color: #fff;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .coach-icon {
    font-size: 1.4rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .coach-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.1rem; }
  .coach-phase-tag {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
  }
  .coach-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }

  /* Coach explanation box */
  .coach-explain {
    background: #f0f9ff;
    border: 1px solid #bae6fd;
    border-radius: 0.5rem;
    padding: 0.85rem 1rem;
    font-size: 0.875rem;
    color: #0c4a6e;
    line-height: 1.65;
  }
  .coach-explain strong { color: #0369a1; }

  /* Coach tip box */
  .coach-tip {
    background: #fefce8;
    border: 1px solid #fde047;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.82rem;
    color: #713f12;
    line-height: 1.6;
  }
  .coach-tip::before { content: '💡 '; }

  /* Prompt questions */
  .coach-prompts {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.25rem;
  }
  .coach-prompt-item {
    font-size: 0.82rem;
    color: #475569;
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.55;
  }
  .coach-prompt-item::before { content: '▸ '; position: absolute; left: 0; color: #6366f1; }

  /* ── Input fields ────────────────────────────────────────────────── */
  .field-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .field-group label { font-size: 0.8rem; font-weight: 700; color: #1e293b; }
  .field-group .hint { font-size: 0.75rem; color: #64748b; }
  .field-group input,
  .field-group textarea {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.4rem;
    font-size: 0.9rem;
    font-family: inherit;
    color: #1e293b;
    background: #f8fafc;
    box-sizing: border-box;
    transition: border-color 0.15s, box-shadow 0.15s;
    resize: vertical;
  }
  .field-group input:focus,
  .field-group textarea:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    background: #fff;
  }
  .field-group textarea { min-height: 100px; line-height: 1.6; }

  /* ── Navigation bar ─────────────────────────────────────────────── */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .btn {
    padding: 0.6rem 1.35rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    font-family: inherit;
    transition: background 0.15s, opacity 0.15s;
  }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-primary  { background: #6366f1; color: #fff; }
  .btn-primary:hover:not(:disabled) { background: #4f46e5; }
  .btn-outline  { background: #fff; color: #1e293b; border: 1px solid #e2e8f0; }
  .btn-outline:hover:not(:disabled) { background: #f1f5f9; }
  .btn-success  { background: #16a34a; color: #fff; }
  .btn-success:hover:not(:disabled) { background: #15803d; }
  .btn-danger   { background: #ef4444; color: #fff; }
  .btn-danger:hover:not(:disabled) { background: #dc2626; }

  .nav-spacer { flex: 1; }
  .step-counter { font-size: 0.82rem; color: #94a3b8; white-space: nowrap; }

  /* ── Summary / Export ────────────────────────────────────────────── */
  #summary-view { display: none; }
  .summary-section {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .summary-section-header {
    background: #1e293b;
    color: #fff;
    padding: 0.7rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .summary-section-body { padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .summary-item-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #6366f1;
    margin-bottom: 0.15rem;
  }
  .summary-item-value {
    font-size: 0.9rem;
    color: #1e293b;
    line-height: 1.6;
    white-space: pre-wrap;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.35rem;
    padding: 0.5rem 0.75rem;
  }
  .summary-item-value.empty { color: #94a3b8; font-style: italic; }

  /* ── Print ───────────────────────────────────────────────────────── */
  @media print {
    :global(*) { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    :global(body) { background: #fff !important; font-size: 10pt; color: #000 !important; }
    :global(main) { padding: 0 !important; max-width: none !important; margin: 0 !important; }
    :global(header), :global(footer), :global(nav) { display: none !important; }
    .cmc-page h1 { font-size: 16pt; font-weight: bold; text-align: center; border-bottom: 2pt solid #000; padding-bottom: 5pt; margin-bottom: 12pt; }
    .cmc-page .subtitle, #coach-view, .phase-bar, .step-dots, .nav-bar, .no-print { display: none !important; }
    #summary-view { display: block !important; }
    .summary-section { border: 1pt solid #000; border-radius: 0; margin-bottom: 8pt; break-inside: avoid; }
    .summary-section-header { background: #e8e8e8 !important; color: #000 !important; border-bottom: 1pt solid #000; padding: 4pt 8pt; font-size: 8pt; }
    .summary-item-label { font-size: 7pt; color: #000; }
    .summary-item-value { font-size: 9pt; background: none !important; border: none; padding: 2pt 0; }
  }
</style>

<div class="cmc-page">
  <h1>🗺️ Concept Map Coach</h1>
  <p class="subtitle">
    A guided, phase-by-phase coaching tool for building a complete nursing concept map.
    Work through all 7 phases at your own pace—explanations, prompts, and input fields
    keep your reasoning visible every step of the way.
  </p>

  <!-- Phase progress bar -->
  <div class="phase-bar" id="phase-bar"></div>

  <!-- ── Coach view (wizard) ── -->
  <div id="coach-view">
    <!-- Step dots -->
    <div class="step-dots" id="step-dots"></div>

    <!-- Coach card -->
    <div class="coach-card" id="coach-card"></div>

    <!-- Navigation bar -->
    <div class="nav-bar">
      <button class="btn btn-outline" id="btn-prev" onclick="navigate(-1)">← Back</button>
      <span class="step-counter" id="step-counter"></span>
      <span class="nav-spacer"></span>
      <button class="btn btn-danger no-print" id="btn-reset" onclick="confirmReset()" title="Clear all data and restart">🗑 Reset</button>
      <button class="btn btn-outline no-print" id="btn-copy-json-coach" onclick="copyJSON('btn-copy-json-coach')" title="Copy all your answers as JSON to share">📋 Copy JSON</button>
      <button class="btn btn-outline no-print" id="btn-summary" onclick="showSummary()">Summary</button>
      <button class="btn btn-primary" id="btn-next" onclick="navigate(1)">Next →</button>
    </div>
  </div>

  <!-- ── Summary / Export view ── -->
  <div id="summary-view">
    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:1.25rem; flex-wrap:wrap;" class="no-print">
      <button class="btn btn-outline" onclick="showCoach()">← Back to Coach</button>
      <button class="btn btn-primary" onclick="window.print()">🖨 Print / Save PDF</button>
      <button class="btn btn-success" onclick="exportJSON()">⬇ Export JSON</button>
      <button class="btn btn-outline" id="btn-copy-json-summary" onclick="copyJSON('btn-copy-json-summary')">📋 Copy JSON</button>
      <button class="btn btn-outline" onclick="importJSON()">⬆ Import JSON</button>
    </div>
    <div id="summary-content"></div>
  </div>
</div>

<script is:inline>
/* ===================================================================
   DATA MODEL — all 7 phases, each with steps
   =================================================================== */
const PHASES = [
  {
    id: 'p1',
    label: 'Phase 1',
    title: 'Data Collection (Assessment)',
    icon: '🔍',
    color: '#0ea5e9',
    steps: [
      {
        id: 'p1s1',
        title: 'Chart Review',
        explain: `Begin with a comprehensive review of the medical record before entering the patient's room. This establishes the clinical context and gives you a working hypothesis before you conduct your physical assessment.`,
        tip: `Review the admitting diagnosis, reason for hospitalisation, past medical/surgical history, all progress notes, current physician orders, and any pending results. What do you already know about this patient?`,
        prompts: [
          'What is the admitting diagnosis and reason for hospitalisation?',
          'What relevant past medical/surgical history is documented?',
          'What current physician orders are in place?',
          'Are there any outstanding lab results or pending studies?',
        ],
        fields: [
          { id: 'chartReview', label: 'Chart review findings', hint: 'Admitting Dx, relevant history, current orders, pending results…', type: 'textarea', rows: 5 },
        ],
      },
      {
        id: 'p1s2',
        title: 'Head-to-Toe Physical Assessment',
        explain: `The systematic head-to-toe physical examination generates your objective data—the signs that are visible, audible, palpable, or measurable. This provides direct, first-hand knowledge of the patient's current physical state.`,
        tip: `Work top-to-bottom: neuro → HEENT → respiratory → cardiovascular → GI → GU → musculoskeletal → integumentary → peripheral. Include vital signs (BP, HR, RR, SpO₂, temp, pain), pupil response, breath sounds, heart sounds, bowel sounds, skin integrity, peripheral pulses, and edema.`,
        prompts: [
          'What are the current vital signs?',
          'What abnormal findings did you note in each body system?',
          'What is the patient\'s neurological status?',
          'Are there any skin integrity concerns?',
        ],
        fields: [
          { id: 'vitalSigns', label: 'Vital signs', hint: 'BP, HR, RR, SpO₂, Temp, Pain score…', type: 'textarea', rows: 2 },
          { id: 'physicalFindings', label: 'Physical assessment findings (head-to-toe)', hint: 'Document findings by system. Note abnormals explicitly.', type: 'textarea', rows: 7 },
        ],
      },
      {
        id: 'p1s3',
        title: 'Patient & Family Interview',
        explain: `Subjective data—the symptoms, concerns, values, and goals that only the patient can report—are gathered through therapeutic interviewing. Family or carers can provide corroborating history and insight into functional baseline and home environment.`,
        tip: `Use open-ended questions: "Tell me about what brought you in today." Ask about the chief complaint using OLDCARTS (Onset, Location, Duration, Character, Aggravating/Relieving factors, Timing, Severity). Ask about pain, functional limitations, understanding of their illness, and concerns.`,
        prompts: [
          'What is the patient\'s chief complaint in their own words?',
          'What symptoms does the patient describe? (OLDCARTS)',
          'What are the patient\'s primary concerns and priorities?',
          'What does the patient/family understand about the diagnosis and plan?',
        ],
        fields: [
          { id: 'subjectiveData', label: 'Subjective data (patient/family interview)', hint: 'Chief complaint, symptoms, concerns, values, goals, functional baseline…', type: 'textarea', rows: 5 },
        ],
      },
      {
        id: 'p1s4',
        title: 'Review Diagnostics',
        explain: `Laboratory values, imaging reports, ECGs, cultures, and vital sign trends are reviewed and interpreted in the context of the patient's full clinical picture. A serum lactate of 4.2 in a febrile, hypotensive patient means something very different from one in a post-op patient.`,
        tip: `Note values that are outside reference ranges. Identify trends—is a value worsening, improving, or stable? Compare to prior results if available. Consider what each abnormal value means for your patient's clinical picture.`,
        prompts: [
          'Which lab values are outside normal ranges? What is the clinical significance?',
          'What do imaging or other diagnostic results show?',
          'Are any values trending in a clinically significant direction?',
        ],
        fields: [
          { id: 'labValues', label: 'Key lab results', hint: 'CBC, BMP, ABG, lactate, cultures, coagulation, etc. Note abnormals.', type: 'textarea', rows: 4 },
          { id: 'diagnosticResults', label: 'Imaging / ECG / other diagnostic findings', hint: 'CXR, CT, echo, ECG interpretation…', type: 'textarea', rows: 3 },
        ],
      },
      {
        id: 'p1s5',
        title: 'Medication Reconciliation',
        explain: `A complete medication reconciliation with dosages, routes, frequencies, indications, and clinically significant side effects is essential. Many nursing diagnoses arise directly from pharmacological effects—constipation from opioids, hyponatraemia from diuretics, fall risk from sedatives.`,
        tip: `For each medication, ask: What is it for? What are the key nursing considerations? What adverse effects are relevant for this patient? Which medications interact with this patient's current condition?`,
        prompts: [
          'What medications is this patient currently receiving?',
          'Which medications have nursing considerations that impact this patient?',
          'Are any medications contributing to problems you have identified?',
        ],
        fields: [
          { id: 'medications', label: 'Current medications & nursing considerations', hint: 'Drug, dose, route, frequency, indication, key nursing concern…', type: 'textarea', rows: 6 },
        ],
      },
    ],
  },
  {
    id: 'p2',
    label: 'Phase 2',
    title: 'Data Organisation',
    icon: '📊',
    color: '#8b5cf6',
    steps: [
      {
        id: 'p2s1',
        title: 'Cluster Related Data',
        explain: `Raw assessment data does not automatically constitute clinical understanding. Clustering groups signs and symptoms that share a common physiological, psychological, or contextual basis—revealing patterns that point toward specific nursing diagnoses.`,
        tip: `Example cluster → "decreased breath sounds at right base + dullness to percussion + SpO₂ 91% + productive cough" all point toward a respiratory problem. Give each cluster a short descriptive label. A patient typically has 3–6 meaningful clusters.`,
        prompts: [
          'What findings naturally group together based on a shared body system or problem?',
          'Are there cues from assessment, labs, medications, and subjective data that cluster together?',
          'What pattern does each cluster suggest?',
        ],
        fields: [
          { id: 'dataClusters', label: 'Data clusters (group related findings)', hint: 'Cluster 1: [label] — findings…\nCluster 2: [label] — findings…\n(continue for each cluster)', type: 'textarea', rows: 8 },
        ],
      },
      {
        id: 'p2s2',
        title: 'Identify Abnormal Findings',
        explain: `Within each cluster, explicitly flag values that fall outside established normal ranges or that represent a departure from this patient's personal baseline. Clinical significance is always relative to context and to the individual patient's baseline.`,
        tip: `A heart rate of 98 bpm in a patient whose normal is 60 bpm may signal early compromise even though 98 is "within normal limits." Always compare to the patient's own baseline when possible, not just textbook ranges.`,
        prompts: [
          'Which specific findings are abnormal compared to reference ranges?',
          'Which findings are abnormal relative to this patient\'s personal baseline?',
          'Which abnormal findings are most clinically significant and why?',
        ],
        fields: [
          { id: 'abnormalFindings', label: 'Abnormal findings & their clinical significance', hint: 'List each abnormal value/finding and explain why it matters for this patient.', type: 'textarea', rows: 5 },
        ],
      },
      {
        id: 'p2s3',
        title: 'Separate Medical vs. Nursing Diagnoses',
        explain: `A critical distinction: the medical diagnosis names the disease/pathology identified by the physician (e.g., community-acquired pneumonia). The nursing diagnosis names the patient's human response to that disease (e.g., impaired gas exchange, activity intolerance, anxiety). The concept map is organised around nursing diagnoses.`,
        tip: `Ask yourself: "Can I independently treat this, or does it require a physician order?" Nursing diagnoses address responses to illness—physiological, psychological, safety, self-care, knowledge—that are within nursing scope of practice.`,
        prompts: [
          'What is the medical diagnosis (physician\'s domain)?',
          'What are the patient\'s human responses to that diagnosis that nursing can address?',
          'Are there problems in areas like safety, self-care, knowledge, coping, or comfort?',
        ],
        fields: [
          { id: 'medicalDiagnoses', label: 'Medical diagnosis / diagnoses (physician\'s domain)', hint: 'The underlying disease(s) or pathological conditions…', type: 'textarea', rows: 2 },
          { id: 'nursingFocus', label: 'Human responses & nursing concerns identified', hint: 'The patient\'s responses that nursing can address—these will become nursing diagnoses in Phase 3…', type: 'textarea', rows: 4 },
        ],
      },
      {
        id: 'p2s4',
        title: 'Place the Central Concept',
        explain: `The hub of the concept map is the patient's identity and primary nursing concern—not just the medical diagnosis, but the patient as a whole person with specific problems, priorities, and circumstances. All branches radiate outward from this central node.`,
        tip: `The central concept typically includes the patient's name/identifier, age, primary medical diagnosis, and the one or two most pressing nursing concerns. It is the anchor from which all diagnostic, intervention, and outcome branches extend.`,
        prompts: [
          'How would you summarise this patient in one concise statement?',
          'What is the single most urgent concern dominating this patient\'s care?',
        ],
        fields: [
          { id: 'centralConcept', label: 'Central concept (map hub)', hint: 'E.g., "Mr. X, 68 y/o male, admitted with AECOPD — primary concern: Impaired Gas Exchange with acute respiratory decompensation."', type: 'textarea', rows: 3 },
        ],
      },
    ],
  },
  {
    id: 'p3',
    label: 'Phase 3',
    title: 'Clinical Reasoning & Nursing Diagnosis',
    icon: '🧠',
    color: '#6366f1',
    steps: [
      {
        id: 'p3s1',
        title: 'Analyse Data Clusters',
        explain: `Each cluster assembled in Phase 2 is now interrogated: what problem do these cues collectively point to? What is the underlying pathophysiology connecting these findings? Are there competing explanations that must be considered?`,
        tip: `Avoid premature closure (settling on the first plausible answer) and diagnostic paralysis (inability to commit). For each cluster, state what you believe is happening and why. Connect the pathophysiology to the clinical findings.`,
        prompts: [
          'For each cluster, what clinical problem does the pattern suggest?',
          'What pathophysiology explains the connection between these findings?',
          'Are there competing diagnoses you need to rule out?',
        ],
        fields: [
          { id: 'clusterAnalysis', label: 'Cluster analysis (what each cluster suggests)', hint: 'Cluster 1 → suggests [problem] because [pathophysiology]…\nCluster 2 → suggests…', type: 'textarea', rows: 7 },
        ],
      },
      {
        id: 'p3s2',
        title: 'Formulate Nursing Diagnoses',
        explain: `Nursing diagnoses are expressed in the three-part NANDA format:\n• Problem (P): the human response — e.g., "Ineffective Airway Clearance"\n• Related To (R/T): the aetiology — e.g., "R/T excessive mucus secondary to pneumonia"\n• As Evidenced By (AEB): defining characteristics from assessment — e.g., "AEB decreased breath sounds, SpO₂ 91%, productive cough"`,
        tip: `Every nursing diagnosis must be directly traceable to assessment data. The AEB clause proves you didn't invent the diagnosis—it grounds your reasoning in evidence. Use NANDA-I approved labels whenever possible.`,
        prompts: [
          'Write each nursing diagnosis in full P+R/T+AEB format.',
          'Is each diagnosis directly supported by your assessment data (AEB)?',
          'Have you considered diagnoses in all domains: physiological, safety, self-care, psychosocial, knowledge?',
        ],
        fields: [
          { id: 'nursingDiagnoses', label: 'Nursing diagnoses (NANDA P + R/T + AEB format)', hint: 'Dx 1: [Problem] R/T [aetiology] AEB [defining characteristics]\nDx 2: …\n(list all)', type: 'textarea', rows: 9 },
        ],
      },
      {
        id: 'p3s3',
        title: 'Prioritise Diagnoses',
        explain: `When multiple nursing diagnoses are present—as almost always in acute care—determine which to address first. Apply two complementary frameworks:\n• ABC (Airway → Breathing → Circulation): life-threatening physiological threats are addressed before all others\n• Maslow's Hierarchy: physiological needs > safety > belonging > esteem > self-actualisation\nAlso incorporate the patient's own stated priorities.`,
        tip: `List your diagnoses in priority order. If a patient has impaired gas exchange AND risk for falls, gas exchange is higher priority even if the patient complains most about pain. Justify your ranking by naming which framework applies.`,
        prompts: [
          'Which diagnosis is highest priority and why (ABC or Maslow)?',
          'What is the patient\'s stated priority—and how does it factor into your ranking?',
          'Are there any diagnoses that, if unaddressed, would worsen others (cascade effect)?',
        ],
        fields: [
          { id: 'prioritisedDx', label: 'Prioritised nursing diagnoses (highest → lowest)', hint: '#1 [Diagnosis] — priority rationale: [ABC/Maslow/patient priority]…\n#2 …', type: 'textarea', rows: 7 },
        ],
      },
    ],
  },
  {
    id: 'p4',
    label: 'Phase 4',
    title: 'Goal & Outcome Setting',
    icon: '🎯',
    color: '#0f766e',
    steps: [
      {
        id: 'p4s1',
        title: 'Write SMART Outcomes',
        explain: `For each nursing diagnosis, write at least one goal statement that is:\n• Specific — clearly describes what the patient will do/demonstrate\n• Measurable — includes objective criteria (a number, behaviour, or observable finding)\n• Attainable — realistic given the patient's current condition\n• Realistic — aligned with overall prognosis and trajectory\n• Time-bound — specifies the timeframe for achievement`,
        tip: `Example: "Patient will maintain SpO₂ ≥ 94% on ≤ 2 L/min nasal cannula and report dyspnoea ≤ 2/10 within 24 hours of initiating treatment." Note the measurable threshold (94%, ≤2 L/min, ≤2/10) and the timeframe (24 hours).`,
        prompts: [
          'For each priority diagnosis, what does success look like—measurably?',
          'What specific number, behaviour, or observable sign will tell you the goal has been met?',
          'Is the goal realistic for this patient\'s current condition and likely clinical trajectory?',
          'What is the timeframe? (Shift? 24 hours? Before discharge?)',
        ],
        fields: [
          { id: 'smartGoals', label: 'SMART outcomes for each nursing diagnosis', hint: 'Dx 1 goal: Patient will [specific, measurable outcome] by [timeframe].\nDx 2 goal: …', type: 'textarea', rows: 8 },
        ],
      },
      {
        id: 'p4s2',
        title: 'Short-Term vs. Long-Term Goals',
