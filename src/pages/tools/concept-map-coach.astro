/* ===================================================================
   STATE
   =================================================================== */
let currentPhase = 0;
let currentStep  = 0;
const answers = {}; // keyed by field id

/* ===================================================================
   INIT
   =================================================================== */
document.addEventListener('DOMContentLoaded', () => {
  loadFromStorage();
  renderPhaseBar();
  renderStep();
});

/* ===================================================================
   STORAGE
   =================================================================== */
const STORAGE_KEY = 'cmCoach_v1';

function saveToStorage() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ currentPhase, currentStep, answers }));
  } catch (err) {
    console.warn('[ConceptMapCoach] Auto-save failed:', err);
    // Notify the user once per session so they know to use Export JSON as a backup
    if (!saveToStorage._warned) {
      saveToStorage._warned = true;
      alert('⚠️ Auto-save to browser storage failed (storage may be full or disabled).\nUse "Export JSON" or "Copy JSON" to save your work manually.');
    }
  }
}

function loadFromStorage() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    const data = JSON.parse(raw);
    currentPhase = data.currentPhase || 0;
    currentStep  = data.currentStep  || 0;
    Object.assign(answers, data.answers || {});
  } catch (err) {
    console.warn('[ConceptMapCoach] Could not load saved data (may be corrupted):', err);
    // Clear the corrupted entry so the next save works cleanly
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
  }
}

function confirmReset() {
  if (!confirm('Clear all your data and start over? This cannot be undone.')) return;
  localStorage.removeItem(STORAGE_KEY);
  currentPhase = 0;
  currentStep  = 0;
  for (const k of Object.keys(answers)) delete answers[k];
  renderPhaseBar();
  renderStep();
  showCoach();
}

/* ===================================================================
   NAVIGATION
   =================================================================== */
function navigate(dir) {
  saveCurrentAnswers();
  const phase = PHASES[currentPhase];
  const nextStep = currentStep + dir;

  if (nextStep >= 0 && nextStep < phase.steps.length) {
    currentStep = nextStep;
  } else if (dir > 0 && currentPhase < PHASES.length - 1) {
    currentPhase++;
    currentStep = 0;
  } else if (dir < 0 && currentPhase > 0) {
    currentPhase--;
    currentStep = PHASES[currentPhase].steps.length - 1;
  }
  saveToStorage();
  renderPhaseBar();
  renderStep();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function jumpToPhase(phaseIdx) {
  saveCurrentAnswers();
  currentPhase = phaseIdx;
  currentStep  = 0;
  saveToStorage();
  renderPhaseBar();
  renderStep();
  showCoach();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function jumpToStep(stepIdx) {
  saveCurrentAnswers();
  currentStep = stepIdx;
  saveToStorage();
  renderPhaseBar();
  renderStep();
}

/* ===================================================================
   SAVE ANSWERS FROM DOM
   =================================================================== */
function saveCurrentAnswers() {
  const phase = PHASES[currentPhase];
  const step  = phase.steps[currentStep];
  for (const field of step.fields) {
    const el = document.getElementById('field_' + field.id);
    if (el) answers[field.id] = el.value;
  }
}

/* ===================================================================
   CHECK IF PHASE IS COMPLETE
   =================================================================== */
function isPhaseComplete(phaseIdx) {
  const phase = PHASES[phaseIdx];
  return phase.steps.every(step =>
    step.fields.every(f => answers[f.id] && answers[f.id].trim().length > 0)
  );
}

/* ===================================================================
   RENDER — PHASE BAR
   =================================================================== */
function renderPhaseBar() {
  const bar = document.getElementById('phase-bar');
  bar.innerHTML = PHASES.map((p, i) => {
    const cls = i === currentPhase ? 'active' : (isPhaseComplete(i) ? 'done' : '');
    return `<div class="phase-pip ${cls}" onclick="jumpToPhase(${i})" title="${p.title}">${p.label}<br><span style="font-weight:400;opacity:0.8;">${p.icon}</span></div>`;
  }).join('');
}

/* ===================================================================
   RENDER — STEP
   =================================================================== */
function renderStep() {
  const phase = PHASES[currentPhase];
  const step  = phase.steps[currentStep];
  const totalSteps = phase.steps.length;
  const globalStep = PHASES.slice(0, currentPhase).reduce((s, p) => s + p.steps.length, 0) + currentStep + 1;
  const totalGlobal = PHASES.reduce((s, p) => s + p.steps.length, 0);

  // Step dots
  const dotsEl = document.getElementById('step-dots');
  dotsEl.innerHTML = phase.steps.map((s, i) => {
    const fieldsDone = s.fields.every(f => answers[f.id] && answers[f.id].trim().length > 0);
    const cls = i === currentStep ? 'active' : (fieldsDone ? 'done' : '');
    return `<div class="step-dot ${cls}" onclick="jumpToStep(${i})" title="${s.title}"></div>`;
  }).join('') + `<span class="step-label">${phase.title} — Step ${currentStep + 1} of ${totalSteps}</span>`;

  // Coach card
  const card = document.getElementById('coach-card');
  const promptsHTML = step.prompts.map(p =>
    `<div class="coach-prompt-item">${escHtml(p)}</div>`
  ).join('');
  const fieldsHTML = step.fields.map(f => {
    const val = answers[f.id] || '';
    if (f.type === 'textarea') {
      return `<div class="field-group">
        <label for="field_${f.id}">${escHtml(f.label)}</label>
        ${f.hint ? `<span class="hint">${escHtml(f.hint)}</span>` : ''}
        <textarea id="field_${f.id}" rows="${f.rows || 4}" placeholder="${escHtml(f.hint || '')}">${escHtml(val)}</textarea>
      </div>`;
    }
    return `<div class="field-group">
      <label for="field_${f.id}">${escHtml(f.label)}</label>
      ${f.hint ? `<span class="hint">${escHtml(f.hint)}</span>` : ''}
      <input type="text" id="field_${f.id}" value="${escHtml(val)}" placeholder="${escHtml(f.hint || '')}">
    </div>`;
  }).join('');

  const explainParas = step.explain.split('\n').map(l => `<p style="margin:0 0 0.35rem;">${escHtml(l)}</p>`).join('');
  const tipText = step.tip.split('\n').map(l => escHtml(l)).join('<br>');

  card.innerHTML = `
    <div class="coach-header" style="background:${escHtml(phase.color)};">
      <div class="coach-icon">${step.icon || phase.icon}</div>
      <div>
        <div class="coach-phase-tag">${escHtml(phase.label)} · ${escHtml(phase.title)}</div>
        <div class="coach-title">${escHtml(step.title)}</div>
      </div>
    </div>
    <div class="coach-body">
      <div class="coach-explain">${explainParas}</div>
      <div class="coach-tip">${tipText}</div>
      <div>
        <div style="font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:#475569; margin-bottom:0.5rem;">Guiding questions</div>
        <div class="coach-prompts">${promptsHTML}</div>
      </div>
      ${fieldsHTML}
    </div>`;

  // Navigation
  const btnPrev = document.getElementById('btn-prev');
  const btnNext = document.getElementById('btn-next');
  const counter = document.getElementById('step-counter');

  const isFirst = currentPhase === 0 && currentStep === 0;
  const isLast  = currentPhase === PHASES.length - 1 && currentStep === phase.steps.length - 1;

  btnPrev.disabled = isFirst;
  btnNext.textContent = isLast ? '📋 View Summary' : 'Next →';
  btnNext.className = isLast ? 'btn btn-success' : 'btn btn-primary';
  btnNext.onclick = isLast ? () => { saveCurrentAnswers(); showSummary(); } : () => navigate(1);

  counter.textContent = `Step ${globalStep} of ${totalGlobal}`;
}

/* ===================================================================
   SUMMARY VIEW
   =================================================================== */
function showSummary() {
  saveCurrentAnswers();
  saveToStorage();
  document.getElementById('coach-view').style.display = 'none';
  document.getElementById('summary-view').style.display = 'block';
  renderSummary();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showCoach() {
  document.getElementById('summary-view').style.display = 'none';
  document.getElementById('coach-view').style.display = 'block';
  renderPhaseBar();
  renderStep();
}

function renderSummary() {
  const content = document.getElementById('summary-content');
  let html = '';
  for (const phase of PHASES) {
    const stepsHTML = phase.steps.map(step => {
      return step.fields.map(f => {
        const val = (answers[f.id] || '').trim();
        const cls = val ? '' : 'empty';
        return `<div>
          <div class="summary-item-label">${escHtml(step.title)} — ${escHtml(f.label)}</div>
          <div class="summary-item-value ${cls}">${val ? escHtml(val) : '(not yet completed)'}</div>
        </div>`;
      }).join('');
    }).join('');

    html += `<div class="summary-section">
      <div class="summary-section-header" style="background:${escHtml(phase.color)};">
        ${escHtml(phase.icon)} ${escHtml(phase.label)}: ${escHtml(phase.title)}
      </div>
      <div class="summary-section-body">${stepsHTML}</div>
    </div>`;
  }
  content.innerHTML = html;
}

/* ===================================================================
   EXPORT / IMPORT JSON
   =================================================================== */
function exportJSON() {
  saveCurrentAnswers();
  const data = { version: 1, timestamp: new Date().toISOString(), answers };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'concept-map-coach-' + new Date().toISOString().slice(0, 10) + '.json';
  a.click();
}

async function copyJSON(btnId) {
  saveCurrentAnswers();
  const data = { version: 1, timestamp: new Date().toISOString(), answers };
  const text = JSON.stringify(data, null, 2);
  const btn = document.getElementById(btnId);

  function markCopied() {
    if (!btn) return;
    const orig = btn.textContent;
    btn.textContent = '✅ Copied!';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000);
  }

  // Try modern Clipboard API first
  if (navigator.clipboard && navigator.clipboard.writeText) {
    try {
      await navigator.clipboard.writeText(text);
      markCopied();
      return;
    } catch (err) {
      console.warn('[ConceptMapCoach] Clipboard API failed, trying execCommand fallback:', err);
    }
  }

  // execCommand fallback (deprecated but still widely supported)
  try {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    const ok = document.execCommand('copy');
    document.body.removeChild(ta);
    if (ok) { markCopied(); return; }
  } catch (err) {
    console.warn('[ConceptMapCoach] execCommand fallback failed:', err);
  }

  // Last resort: show a dialog with the text so the user can copy manually
  showCopyModal(text);
}

function showCopyModal(text) {
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;';
  overlay.innerHTML = `
    <div style="background:#fff;border-radius:.75rem;max-width:560px;width:100%;padding:1.5rem;display:flex;flex-direction:column;gap:1rem;">
      <p style="font-size:.9rem;font-weight:700;color:#1e293b;margin:0;">Automatic copy is not available in this browser</p>
      <p style="font-size:.82rem;color:#475569;margin:0;">Select all the text below and copy it manually (Ctrl+A then Ctrl+C):</p>
      <textarea readonly rows="10" style="width:100%;font-size:.8rem;font-family:monospace;border:1px solid #e2e8f0;border-radius:.4rem;padding:.5rem;resize:vertical;box-sizing:border-box;" onclick="this.select()">${escHtml(text)}</textarea>
      <button onclick="this.closest('div').parentElement.remove()" style="align-self:flex-end;padding:.5rem 1.25rem;background:#6366f1;color:#fff;border:none;border-radius:.4rem;font-size:.875rem;font-weight:600;cursor:pointer;">Close</button>
    </div>`;
  document.body.appendChild(overlay);
  // Auto-select the textarea for convenience
  const ta = overlay.querySelector('textarea');
  if (ta) { setTimeout(() => { ta.focus(); ta.select(); }, 50); }
}

function importJSON() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json,application/json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      try {
        const data = JSON.parse(ev.target.result);
        if (data && data.answers) {
          Object.assign(answers, data.answers);
          saveToStorage();
          renderSummary();
          alert('Data imported successfully!');
        } else {
          alert('Import failed: the file does not contain valid Concept Map Coach data (missing "answers" key).');
        }
      } catch (err) {
        alert('Import failed: the file could not be parsed as JSON.\n\nDetails: ' + err.message);
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

/* ===================================================================
   UTILITY
   =================================================================== */
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
</script>

