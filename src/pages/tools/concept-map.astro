  /* ── Load a sample case into the form ───────────────────────── */
  window.loadCase = function () {
    var sel = document.getElementById('case-select');
    if (!sel || sel.value === '') { alert('Please select a case from the dropdown first.'); return; }
    var caseLabel = sel.options[sel.selectedIndex].text;
    var c = CASES[parseInt(sel.value, 10)];
    if (!c) return;
    if (!confirm('Load "' + caseLabel + '"? This will overwrite any data currently in the form.')) return;

    /* Focus topic */
    var ft = document.getElementById('focus-topic');
    if (ft) ft.value = c.focusTopic;

    /* Pathophysiology */
    var patho = document.getElementById('pathophysiology');
    if (patho) patho.value = c.pathophysiology;

    /* Risk factors */
    document.querySelectorAll('.risk-factor').forEach(function (el, i) {
      el.value = c.riskFactors[i] || '';
    });

    /* Cues */
    document.querySelectorAll('.cue').forEach(function (el, i) {
      el.value = c.cues[i] || '';
    });

    /* Supporting analysis */
    document.querySelectorAll('.supporting').forEach(function (el, i) {
      el.value = c.supporting[i] || '';
    });

    /* Concerning cues */
    document.querySelectorAll('.concerning').forEach(function (el, i) {
      el.value = c.concerning[i] || '';
    });

    /* Hypotheses */
    document.querySelectorAll('.hypothesis').forEach(function (el, i) {
      el.value = c.hypotheses[i] || '';
    });

    /* Solutions / Goals */
    document.querySelectorAll('.solution').forEach(function (el, i) {
      el.value = c.solutions[i] || '';
    });

    /* Actions */
    document.querySelectorAll('.action').forEach(function (el, i) {
      el.value = c.actions[i] || '';
    });

    /* Outcomes */
    document.querySelectorAll('.outcome').forEach(function (el, i) {
      el.value = c.outcomes[i] || '';
    });

    /* Reflow textareas and persist */
    document.querySelectorAll('textarea').forEach(function (ta) { autosize(ta); });
    save();
    syncPrintCard();

    /* Scroll to top of the form content */
    var root = document.getElementById('concept-map-root');
    if (root) root.scrollIntoView({ behavior: 'smooth' });
  };

  /* ── Clear all ───────────────────────────────────────────────── */
  window.clearAll = function () {
    if (!confirm('Clear all fields? This cannot be undone.')) return;
    document.querySelectorAll('input, textarea').forEach(function (el) {
      el.value = '';
      if (el.tagName === 'TEXTAREA') el.style.height = 'auto';
    });
    try { sessionStorage.removeItem(STORE_KEY); } catch (_) {}
    syncPrintCard();
  };

  /* ── Init ────────────────────────────────────────────────────── */
  function init() {
    restore();
    syncPrintCard();

    document.querySelectorAll('input, textarea').forEach(function (el) {
      if (el.tagName === 'TEXTAREA') autosize(el);
      el.addEventListener('input', function () {
        if (el.tagName === 'TEXTAREA') autosize(el);
        save();
        syncPrintCard();
      });
    });

    /* Set today as default date if blank */
    var dateEl = document.getElementById('submission-date');
    if (dateEl && !dateEl.value) {
      var today = new Date();
      var mm = String(today.getMonth() + 1).padStart(2, '0');
      var dd = String(today.getDate()).padStart(2, '0');
      dateEl.value = today.getFullYear() + '-' + mm + '-' + dd;
      syncPrintCard();   // isoToDisplay is used inside syncPrintCard
      save();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Show student info print card before printing */
  window.addEventListener('beforeprint', function () {
    syncPrintCard();
    var card = document.getElementById('student-info-card');
    if (card) card.style.display = 'flex';
    /* Expand all textareas for print */
    document.querySelectorAll('textarea').forEach(function (ta) {
      ta.style.height = 'auto';
      ta.style.height = ta.scrollHeight + 'px';
    });
  });
  window.addEventListener('afterprint', function () {
    var card = document.getElementById('student-info-card');
    if (card) card.style.display = 'none';
  });
})();
</script>

