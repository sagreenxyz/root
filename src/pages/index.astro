---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL || '').replace(/\/$/, '');
---

<Layout title="Welcome – Root" protected={true}>
  <div style="text-align:center; padding: 4rem 1rem 3rem;">
    <div style="font-size:3.5rem; margin-bottom:1rem;">⚡</div>
    <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:1rem; line-height:1.2;">Welcome to Root</h1>
    <p style="color:#64748b; font-size:1.15rem; max-width:560px; margin:0 auto 2.5rem;">
      A clean, fast, and secure site hosted on GitHub Pages. Sign in to access your personal dashboard.
    </p>
    <a
      href={`${base}/dashboard`}
      style="display:inline-block; background:#6366f1; color:#fff; padding:0.85rem 2.25rem; border-radius:0.6rem; text-decoration:none; font-size:1rem; font-weight:600; transition:background 0.2s;"
      onmouseover="this.style.background='#4f46e5'"
      onmouseout="this.style.background='#6366f1'"
    >Go to Dashboard →</a>
  </div>

  <div style="display:grid; gap:1.25rem; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); margin-top:2rem;">
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.75rem;">
      <div style="font-size:1.75rem; margin-bottom:0.75rem;">🔐</div>
      <h2 style="font-size:1rem; font-weight:700; margin-bottom:0.4rem;">Secure Access</h2>
      <p style="color:#64748b; font-size:0.9rem;">Credentials are hashed client-side with SHA-256. No passwords are stored or transmitted.</p>
    </div>
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.75rem;">
      <div style="font-size:1.75rem; margin-bottom:0.75rem;">⚡</div>
      <h2 style="font-size:1rem; font-weight:700; margin-bottom:0.4rem;">Fast & Static</h2>
      <p style="color:#64748b; font-size:0.9rem;">Built with Astro and deployed as a static site on GitHub Pages for maximum performance.</p>
    </div>
    <div style="background:#fff; border:1px solid #e2e8f0; border-radius:0.75rem; padding:1.75rem;">
      <div style="font-size:1.75rem; margin-bottom:0.75rem;">📊</div>
      <h2 style="font-size:1rem; font-weight:700; margin-bottom:0.4rem;">Private Dashboard</h2>
      <p style="color:#64748b; font-size:0.9rem;">Authorized users get a personal dashboard with key stats and session info.</p>
    </div>
  </div>
</Layout>
