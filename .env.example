# Authentication credentials for local development.
# Copy this file to .env.local and fill in your values.
# In production, these are set as GitHub Repository secrets (AUTH_USERNAME and
# AUTH_PASSWORD_HASH) and injected by the GitHub Actions workflow at build time.

# The login username.
PUBLIC_AUTH_USERNAME=admin

# SHA-256 hex digest of the login password.
# Generate with: echo -n "yourpassword" | sha256sum
# Example below is SHA-256 of "admin":
PUBLIC_AUTH_PASSWORD_HASH=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
